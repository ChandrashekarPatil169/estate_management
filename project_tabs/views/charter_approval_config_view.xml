<odoo>
    <!-- View & Action as you defined them -->
<record id="view_charter_approval_matrix_form" model="ir.ui.view">
    <field name="name">charter.approval.matrix.form</field>
    <field name="model">charter.approval.matrix</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <div class="oe_title">
                    <h1><field name="name" placeholder="e.g. Executive Charter Approval"/></h1>
                </div>
                <group>
                    <field name="active" widget="boolean_toggle"/>
                </group>
                <notebook>
                    <page string="Approval Sequence" name="steps">
                        <!-- THE FIX: Wrap the tree in the field tag -->
                        <field name="line_ids">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="user_id" options="{'no_create': True}"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>

    <record id="action_charter_approval_config" model="ir.actions.act_window">
        <field name="name">Charter Approval Matrix</field>
        <field name="res_model">charter.approval.matrix</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- NEW: Menuitem placement -->
    <menuitem id="menu_charter_approval_matrix_config"
              name="Charter Approval Matrix"
              parent="project.menu_project_config"
              action="action_charter_approval_config"
              sequence="50"
              groups="base.group_system"/>
</odoo>
