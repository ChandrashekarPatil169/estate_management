<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- 1. Define the Category (The main App heading) -->
        <record id="module_category_purchase_approval" model="ir.module.category">
            <field name="name">Purchase Approval Management</field>
            <field name="sequence">10</field>
        </record>

        <!-- 2. Define the Privilege (The new Odoo 19 intermediate layer) -->
        <record id="res_groups_privilege_purchase_approval" model="res.groups.privilege">
            <field name="name">Purchase Approvals</field>
            <field name="category_id" ref="module_category_purchase_approval"/>
            <field name="sequence">1</field>
        </record>

        <!-- 3. Define the Group (Link it to the Privilege via privilege_id) -->
        <record id="group_purchase_approver" model="res.groups">
            <field name="name">Purchase Approver</field>
            <!-- Correctly reference the Privilege record defined above -->
            <field name="privilege_id" ref="res_groups_privilege_purchase_approval"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        </record>
    </data>
</odoo>


