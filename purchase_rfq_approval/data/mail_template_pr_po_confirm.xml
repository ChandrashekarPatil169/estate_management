<odoo>
    <data noupdate="0">
        <record id="mail_template_pr_po_confirm" model="mail.template">
            <field name="name">PR Notification - PO Confirmed</field>
            <!-- ✅ CORRECT REF FOR purchase.order -->
            <field name="model_id" ref="purchase.model_purchase_order"/>

            <!-- ✅ HEADERS ON ONE LINE TO PREVENT ERROR -->
            <field name="subject">Purchase Order Confirmed: {{ object.name }}</field>
            <field name="email_from">{{ object.company_id.email }}</field>
            <field name="email_to"></field>

            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p>A Purchase Order has been confirmed for this Purchase Requisition.</p>
                    <ul>
                        <li><b>PR Reference:</b> <t t-out="object.name"/></li>
                        <!-- Ensure these fields exist on purchase.order -->
                        <t t-if="object.partner_id">
                            <li><b>Vendor:</b> <t t-out="object.partner_id.name"/></li>
                        </t>
                        <li><b>Total Amount:</b> <t t-out="object.amount_total"/></li>
                    </ul>
                    <p>Please review the related Purchase Order.</p>
                </div>
            </field>
        </record>
    </data>
</odoo>
