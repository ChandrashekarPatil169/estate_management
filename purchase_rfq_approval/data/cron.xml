<odoo>

    <record id="ir_cron_vendor_rfq_reminder" model="ir.cron">
        <field name="name">Vendor RFQ Reminder</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="state">code</field>
        <field name="code">model._cron_vendor_rfq_reminder()</field>

        <field name="interval_number">1</field>
        <field name="interval_type">days</field>

        <field name="active">True</field>
    </record>

    <record id="ir_cron_po_approval_reminder" model="ir.cron">
        <field name="name">PO Approval Daily Reminder</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="state">code</field>
        <field name="code">model._cron_po_approval_reminder()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>