    <record id="task_timesheet_unit_amount_readonly" model="ir.ui.view">
        <field name="name">project.task.timesheet.unit.amount.readonly</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='timesheet_ids']//field[@name='unit_amount']"
                   position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>
</odoo>