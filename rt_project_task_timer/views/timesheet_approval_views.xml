<odoo>

    <record id="view_timesheet_approval_form" model="ir.ui.view">
        <field name="name">timesheet.approval.form</field>
        <field name="model">timesheet.approval</field>
        <field name="arch" type="xml">
            <form string="Timesheet Approval">
                <header>

                    <button name="action_submit"
                            type="object"
                            string="Submit"
                            invisible="state != 'draft'"/>

                    <button name="action_approve"
                            type="object"
                            string="Approve"
                            class="oe_highlight"
                            invisible="state != 'submitted'"
                            groups="rt_project_task_timer.group_timesheet_approver_custom"/>

                    <button name="action_reject"
                            type="object"
                            string="Reject"
                            invisible="state != 'submitted'"
                            groups="rt_project_task_timer.group_timesheet_approver_custom"/>

                    <button name="action_reset_to_draft"
                            type="object"
                            string="Revert to Draft"
                            invisible="state == 'draft'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,approved,rejected"/>
                </header>

                <sheet>
                    <group>
                        <field name="project_id"/>
                        <field name="parent_task_id"/>
                        <field name="subtask_id"/>
                        <field name="employee_id"/>
<!--                        <field name="date"/>-->
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
<!--                        <field name="unit_amount" widget="float_time"/>-->
<!--                        <field name="unit_amount"/>-->
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_timesheet_approval_list" model="ir.ui.view">
        <field name="name">timesheet.approval.list</field>
        <field name="model">timesheet.approval</field>
        <field name="arch" type="xml">
            <list>
<!--                <field name="date"/>-->
                <field name="employee_id"/>
                <field name="project_id"/>
                <field name="parent_task_id"/>
                <field name="subtask_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
<!--                <field name="unit_amount" widget="float_time"/>-->
<!--                <field name="unit_amount"/>-->
                <field name="state"/>
            </list>
        </field>
    </record>



    <!-- Approval Menu (just filtering analytic lines) -->
    <record id="action_timesheet_request" model="ir.actions.act_window">
        <field name="name">My Timesheet Requests</field>
        <field name="res_model">timesheet.approval</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[
            (ref('view_timesheet_approval_list'), 'list'),
            (ref('view_timesheet_approval_form'), 'form')
        ]"/>
        <field name="view_id" eval="False"/>
    </record>

    <menuitem id="menu_timesheet_request"
              name="My Timesheet Requests"
              parent="hr_timesheet.timesheet_menu_root"
              action="action_timesheet_request"
              groups="rt_project_task_timer.group_timesheet_user_custom"/>

</odoo>