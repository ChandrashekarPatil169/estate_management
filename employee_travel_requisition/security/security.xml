<odoo>

    <record id="group_travel_user" model="res.groups">
        <field name="name">Travel User</field>
    </record>

    <record id="group_travel_manager" model="res.groups">
        <field name="name">Travel Manager</field>
        <field name="implied_ids" eval="[(4, ref('employee_travel_requisition.group_travel_user'))]"/>
    </record>

    <record id="group_travel_hr" model="res.groups">
        <field name="name">Travel HR</field>
        <field name="implied_ids" eval="[(4, ref('employee_travel_requisition.group_travel_manager'))]"/>
    </record>

    <record id="group_travel_officer" model="res.groups">
        <field name="name">Travel Officer</field>
        <field name="implied_ids" eval="[(4, ref('employee_travel_requisition.group_travel_hr'))]"/>
    </record>

    <!-- Expense User -->
    <record id="group_expense_user_custom" model="res.groups">
        <field name="name">Expense User</field>
        <field name="implied_ids" eval="[(4, ref('hr_expense.group_hr_expense_user'))]"/>
    </record>

    <!-- Account Expense User (Manager) -->
    <record id="group_expense_manager_custom" model="res.groups">
        <field name="name">Account Expense User</field>
        <field name="implied_ids" eval="[
                                (4, ref('hr_expense.group_hr_expense_user')),
                                (4, ref('hr_expense.group_hr_expense_manager'))]"/>
    </record>



</odoo>


