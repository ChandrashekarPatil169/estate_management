<odoo>

    <record id="travel_request_hierarchy_rule" model="ir.rule">
        <field name="name">Hierarchy Access</field>
        <field name="model_id" ref="model_travel_request"/>
        <field name="groups" eval="[
            (4, ref('employee_travel_requisition.group_travel_user')),
            (4, ref('employee_travel_requisition.group_travel_manager')),
            (4, ref('employee_travel_requisition.group_travel_hr'))
        ]"/>
        <field name="domain_force">
            ['|','|',
                ('create_uid', '=', user.id),
                ('employee_id.user_id', '=', user.id),
                ('employee_id', 'child_of', user.employee_id.id)
            ]
        </field>
    </record>

    <record id="travel_request_officer_rule" model="ir.rule">
        <field name="name">Officer Full Access</field>
        <field name="model_id" ref="model_travel_request"/>
        <field name="groups" eval="[
            (4, ref('employee_travel_requisition.group_travel_officer'))
        ]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

</odoo>

