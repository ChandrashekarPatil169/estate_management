<odoo>
    <record id="view_travel_expense_account_list" model="ir.ui.view">
        <field name="name">travel.expense.account.list</field>
        <field name="model">travel.expense.account</field>
        <field name="arch" type="xml">
            <list string="Expense Accounts" editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_travel_expense_account_form" model="ir.ui.view">
        <field name="name">travel.expense.account.form</field>
        <field name="model">travel.expense.account</field>
        <field name="arch" type="xml">
            <form string="Expense Account">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- list VIEW -->
    <record id="view_travel_request_list" model="ir.ui.view">
        <field name="name">travel.request.list</field>
        <field name="model">travel.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id" options="{'no_open': True}"/>
                <!--                <field name="destination"/>-->
                <!--                <field name="travel_from"/>-->
                <!--                <field name="travel_to"/>-->
                <field name="first_travel_from"/>
                <field name="first_travel_to"/>
                <field name="state"/>
            </list>
        </field>
    </record>


    <!-- FORM VIEW -->
    <record id="view_travel_request_form" model="ir.ui.view">
        <field name="name">travel.request.form</field>
        <field name="model">travel.request</field>
        <field name="arch" type="xml">
            <form>
                <header>

                    <!-- SUBMIT -->
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <!-- HR BUTTONS -->
                    <button name="action_hr_approve"
                            string="HR Authorized"
                            type="object"
                            class="btn-success"
                            groups="employee_travel_requisition.group_travel_hr"
                            invisible="state != 'hr'"/>

                    <button name="action_hr_reject"
                            string="HR Rejected"
                            type="object"
                            class="btn-danger"
                            groups="employee_travel_requisition.group_travel_hr"
                            invisible="state != 'hr'"/>

                    <!-- DIRECTOR BUTTONS -->
                    <button name="action_director_approve"
                            string="Approve"
                            type="object"
                            class="btn-success"
                            groups="employee_travel_requisition.group_travel_officer"
                            invisible="state != 'director'"/>

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            groups="employee_travel_requisition.group_travel_officer"
                            invisible="state != 'director'"/>

                    <!-- RESET -->
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'rejected'"/>

                    <!-- STATUSBAR -->
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,manager,hr,director,approved,rejected,paid"/>

                </header>

                <!--                <header>-->

                <!--                    &lt;!&ndash; Submit Button &ndash;&gt;-->
                <!--                    <button name="action_submit"-->
                <!--                            string="Submit"-->
                <!--                            type="object"-->
                <!--                            class="btn-primary"-->
                <!--                            invisible="state != 'draft'"/>-->

                <!--                    &lt;!&ndash; Approve Button &ndash;&gt;-->
