                <!--                            type="object"-->
                <!--                            invisible="state != 'rejected'"/>-->


                <!--                    <field name="state"-->
                <!--                           widget="statusbar"-->
                <!--                           statusbar_visible="draft,submit,approved,rejected"/>-->


                <!--                </header>-->


                <sheet>
                    <div class="oe_button_box" name="button_box">

                        <button name="action_open_documents"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-paperclip">

                            <field name="attachment_count"
                                   widget="statinfo"
                                   string="Documents"/>

                        </button>

                    </div>

                    <!-- BIG TITLE -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- TOP INFO BLOCK -->
                    <group col="2">

                        <group>
                            <field name="employee_id" options="{'no_open': True}"/>
