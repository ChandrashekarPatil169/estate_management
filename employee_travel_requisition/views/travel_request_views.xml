                                    <button name="action_approve_line"
                                            type="object"
                                            string="Approve"
                                            groups="employee_travel_requisition.group_travel_manager"
                                            invisible="status in ('approved','rejected') or parent.state == 'draft'"/>

                                    <button name="action_reject_line"
