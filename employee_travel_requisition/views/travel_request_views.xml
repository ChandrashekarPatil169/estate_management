    <record id="view_attachment_tree_travel" model="ir.ui.view">
        <field name="name">ir.attachment.tree.travel</field>
        <field name="model">ir.attachment</field>
        <field name="inherit_id" ref="base.view_attachment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="travel_line_description"/>
                <!--                <field name="travel_doc_type"/>-->
            </xpath>
        </field>
    </record>

    <record id="view_travel_request_search" model="ir.ui.view">
        <field name="name">travel.request.search</field>
        <field name="model">travel.request</field>
        <field name="arch" type="xml">
            <search>

                <!-- FILTERS -->
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="manager" string="Manager" domain="[('state','=','manager')]"/>
                <filter name="hr" string="HR" domain="[('state','=','hr')]"/>
                <filter name="director" string="Director" domain="[('state','=','director')]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <filter name="rejected" string="Rejected" domain="[('state','=','rejected')]"/>

                <!-- STATUS FILTER -->
                <field name="status_id"/>

                <!-- GROUP BY (NO <group> TAG) -->
                <filter name="group_state"
                        string="Group by State"
                        context="{'group_by': 'state'}"/>

                <filter name="group_status"
                        string="Group by Status"
                        context="{'group_by': 'status_id'}"/>

            </search>
        </field>
    </record>

