<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ticket_submit_email_template" model="mail.template">
            <field name="name">Helpdesk Ticket Submit</field>

            <field name="model_id" ref="helpdesk_mgmt.model_helpdesk_ticket"/>

            <field name="email_from">${user.email}</field>
            <field name="email_to">${object.user_id.email}</field>

            <!--            <field name="subject">Ticket Submitted - {object.display_name}</field>-->
            <field name="subject">{{ object.display_name }} Ticket Submitted)</field>

            <field name="auto_delete" eval="False"/>

            <field name="body_html" type="html">
                <div style="padding:16px;background-color:#F1F1F1;font-family:Verdana,Arial,sans-serif;">

                    <div style="background-color:white;padding:24px;max-width:600px;margin:auto;">

                        <h2>Ticket Submitted</h2>
                        <hr/>

                        <p>Dear
                            <span t-out="object.user_id.name"/>
                        </p>

                        <p>A new ticket has been submitted.</p>

                        <p>
                            <b>Ticket:</b>
                            <span t-out="object.display_name"/>
                        </p>

                        <p>Regards<br/>Helpdesk System
                        </p>

                        <hr/>

                        <small>
                            <span t-out="object.company_id.name"/>
                        </small>

                    </div>

                </div>
            </field>
        </record>

        <record id="ticket_assign_email_template" model="mail.template">
            <field name="name">Helpdesk Ticket Assigned</field>

            <field name="model_id" ref="helpdesk_mgmt.model_helpdesk_ticket"/>

            <!-- Sender -->
            <field name="email_from">${user.email}</field>

            <!-- Receiver -->
            <field name="email_to">${object.user_id.email}</field>

            <!-- Subject -->
            <field name="subject">{{ object.display_name }} Ticket Assigned</field>
            <!-- ✅ BODY (QWeb like your working template) -->
            <field name="body_html" type="html">
                <div style="padding:16px;background-color:#F1F1F1;font-family:Verdana,Arial,sans-serif;">

                    <div style="background-color:white;padding:24px;max-width:600px;margin:auto;">

                        <h2>Ticket Assigned</h2>
                        <hr/>

                        <p>Dear
                            <span t-out="object.user_id.name"/>
                        </p>

                        <p>A ticket has been assigned to you.</p>

                        <p>
                            <b>Ticket:</b>
                            <span t-out="object.display_name"/>
                        </p>

                        <p>
                            <b>Assigned By:</b>
                            <span t-out="user.name"/>
                        </p>

                        <p>Regards<br/>Helpdesk System
                        </p>

                        <hr/>

                        <small>
                            <span t-out="object.company_id.name"/>
                        </small>

                    </div>

                </div>
            </field>
        </record>

