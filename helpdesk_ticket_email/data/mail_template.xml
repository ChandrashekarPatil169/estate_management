        <record id="ticket_resolve_email_template" model="mail.template">
            <field name="name">Helpdesk Ticket Resolved</field>

            <field name="model_id" ref="helpdesk_mgmt.model_helpdesk_ticket"/>

            <field name="email_from">${user.email}</field>

            <field name="email_to">
                ${object.manager_id_main.email},${object.requested_person_id.partner_id.email}
            </field>

            <field name="subject">{{ object.display_name }} Ticket Resolved</field>
            <field name="body_html" type="html">
                <div style="padding:16px;background-color:#F1F1F1;font-family:Verdana,Arial,sans-serif;">

                    <div style="background-color:white;padding:24px;max-width:600px;margin:auto;">

                        <h2>Ticket Resolved</h2>
                        <hr/>

                        <p>Dear
                            <span t-out="object.user_id.name"/>
                        </p>

                        <p>The following ticket has been resolved:</p>

                        <p>
                            <b>Ticket:</b>
                            <span t-out="object.display_name"/>
                        </p>

                        <p>
                            <b>Resolved By:</b>
                            <span t-out="object.user_id.name"/>
                        </p>

                        <p>Regards<br/>Helpdesk System
                        </p>

                        <hr/>

                        <small>
                            <span t-out="object.company_id.name"/>
                        </small>

                    </div>

                </div>
            </field>
        </record>


        <record id="ticket_done_email_template" model="mail.template">
            <field name="name">Helpdesk Ticket Closed</field>

            <field name="model_id" ref="helpdesk_mgmt.model_helpdesk_ticket"/>

            <!-- Sender -->
            <field name="email_from">${user.email}</field>

            <!-- Multiple recipients -->
            <field name="email_to">
                ${object.user_id.email},
                ${object.partner_id.email},
                ${','.join(object.message_partner_ids.mapped('email'))}
            </field>

            <!-- Subject -->
            <field name="subject">{{ object.display_name }} Ticket Closed</field>
            <!-- ✅ BODY (QWeb format) -->
            <field name="body_html" type="html">
                <div style="padding:16px;background-color:#F1F1F1;font-family:Verdana,Arial,sans-serif;">

                    <div style="background-color:white;padding:24px;max-width:600px;margin:auto;">

                        <h2>Ticket Closed</h2>
                        <hr/>

                        <p>Dear
                            <span t-out="object.partner_id.name"/>
                        </p>

                        <p>The following ticket has been <b>closed</b>.
                        </p>

                        <p>
                            <b>Ticket:</b>
                            <span t-out="object.display_name"/>
                        </p>

                        <p>
                            <b>Closed By:</b>
                            <span t-out="user.name"/>
                        </p>

                        <p>Regards<br/>Helpdesk System
                        </p>

                        <hr/>

                        <small>
                            <span t-out="object.company_id.name"/>
                        </small>

                    </div>

                </div>
            </field>
        </record>

        <record id="ir_cron_pending_ticket_reminder" model="ir.cron">
            <field name="name">Pending Ticket Approval Reminder</field>
            <field name="model_id" ref="helpdesk_mgmt.model_helpdesk_ticket"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_pending_approval_reminder()</field>
            <field name="interval_number">1</field>
            <field name="nextcall">2026-04-01 11:28:00</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>