<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="ticket_submit_email_template" model="mail.template">
            <field name="name">Helpdesk Ticket - Submitted Notification</field>
            <field name="model_id" ref="helpdesk_mgmt.model_helpdesk_ticket"/>

            <field name="email_from">${object.company_id.email}</field>
            <field name="email_to">${object.manager_id_main.email}</field>

            <field name="subject">Ticket Submitted - ${object.display_name}</field>

            <field name="body_html" type="html">
                <![CDATA[
                <p>Dear ${object.manager_id_main.name},</p>
                <p>A new ticket has been submitted.</p>
                ]]>
            </field>

        </record>

    </data>
</odoo>