<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- 1️⃣ Add HR Department Tab -->
    <record id="view_hr_ticket_form_inherit_hr_department" model="ir.ui.view">
        <field name="name">hr.ticket.form.inherit.hr.department</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="HR Department" name="hr_department"
                      invisible="department_type != 'hr'">
                    <group>
                        <field name="hr_request_type_id"/>
                        <field name="description" placeholder="Enter description..."/>
                        <field name="grievance_policy"/>
                        <field name="incident_date"/>
                        <field name="incident_location"/>
                        <field name="confidential"/>
                    </group>

                    <group string="People Involved">
                        <field name="people_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
    <!-- ========================= -->
    <!-- HR REQUEST TYPE MASTER -->
    <!-- ========================= -->

    <record id="view_helpdesk_hr_request_type_list" model="ir.ui.view">
        <field name="name">helpdesk.hr.request.type.list</field>
        <field name="model">helpdesk.hr.request.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_hr_request_type_form" model="ir.ui.view">
        <field name="name">helpdesk.hr.request.type.form</field>
        <field name="model">helpdesk.hr.request.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_hr_request_type" model="ir.actions.act_window">
        <field name="name">HR Request Type</field>
        <field name="res_model">helpdesk.hr.request.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_assigned_tickets" model="ir.actions.act_window">
        <field name="name">Assigned Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('assign_to', '=', uid)]</field>
    </record>

    <menuitem
            id="menu_assigned_tickets"
            name="Assigned Tickets"
            parent="helpdesk_mgmt.helpdesk_ticket_menu"
            action="action_assigned_tickets"
            sequence="30"/>
    />
    <menuitem id="menu_helpdesk_hr_request_type"
              name="HR Request Type"
              parent="menu_helpdesk_priority_root"
              action="action_helpdesk_hr_request_type"
              sequence="70"/>

</odoo>