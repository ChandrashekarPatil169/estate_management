<odoo>

    <record id="view_helpdesk_ticket_form_inherit_it_assets"
            model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.inherit.it.assets</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form"/>
        <field name="arch" type="xml">

            <!-- Insert new tab inside notebook -->
            <xpath expr="//notebook" position="inside">

                <page string="Inventory and IT Assets"
                      name="inventory"
                      invisible="department_type != 'inventory'">

                    <group>
                        <!--                        <field name="asset_tag"/>-->
                        <!--                        <field name="service_id"/>-->
                        <!--                        <field name="asset_type"/>-->
                        <!--                        <field name="asset_category"/>-->
                        <!--                        <field name="product_name"/>-->
                        <!--                        <field name="brand"/>-->
                        <!--                        <field name="model"/>-->
                        <!--                        <field name="serial_number"/>-->
                        <field name="mac_address"/>
                        <field name="part_number"/>
                        <field name="assigned_user_id"/>
                        <field name="purchase_order_id"/>
                        <field name="invoice_id"/>
                        <field name="warranty_end_at"/>
                        <field name="amc_contract_id"/>
                    </group>

                    <group string="Asset Information" col="4">

                        <field name="asset_inventory_id"/>

                        <field name="asset_type_id" readonly="1"/>
                        <field name="asset_category_id" readonly="1"/>
                        <field name="product_name_id" readonly="1"/>
                        <field name="brand_id" readonly="1"/>
                        <field name="model_id" readonly="1"/>
                        <field name="serial_no" readonly="1"/>
                        <field name="warehouse_id" readonly="1"/>
                        <field name="asset_owner_id" readonly="1"/>

                    </group>

                    <group string="Software / License Linkage" col="2">
                        <field name="related_software_ids"
                               widget="many2many_tags"/>
                        <field name="license_key"/>
                        <field name="license_type"/>
                        <field name="license_expiry"/>
                        <field name="compliance_status"/>
                    </group>

                    <group string="Resolution and Costs" col="2">
                        <field name="resolution_notes"/>
                        <field name="resolution_code"/>

                        <field name="parts_replaced_ids">
                            <list editable="bottom">
                                <field name="item"/>
                                <field name="qty"/>
                                <field name="cost"/>
                            </list>
                        </field>

                        <field name="resolution_cost"/>
                        <field name="chargeback_department_id"/>
                    </group>

                </page>

            </xpath>

        </field>
    </record>

    <record id="view_helpdesk_service_type_list" model="ir.ui.view">
        <field name="name">helpdesk.service.type.list</field>
        <field name="model">helpdesk.service.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Service Type Form View -->
    <record id="view_helpdesk_service_type_form" model="ir.ui.view">
        <field name="name">helpdesk.service.type.form</field>
        <field name="model">helpdesk.service.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="helpdesk_ticket_tree_inherit_order" model="ir.ui.view">
        <field name="name">helpdesk.ticket.tree.order</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="default_order">number desc</attribute>
            </xpath>
        </field>
    </record>

    <!-- Action to open Service Types -->
    <record id="action_helpdesk_service_type" model="ir.actions.act_window">
        <field name="name">Service Type</field>
        <field name="res_model">helpdesk.service.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item to create the "Priority and SLAs" menu -->
    <menuitem id="menu_helpdesk_service_type_root"
              name="Service Type"
              parent="menu_facility_master_root"
              action="action_helpdesk_service_type"
              sequence="40"/>

</odoo>
