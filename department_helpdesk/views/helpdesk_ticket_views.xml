            <xpath expr="//field[@name='urgency_id']" position="before">

                <field name="deadline"/>

                <field name="time_remaining"
                       widget="badge"
                       decoration-success="time_status == 'ok'"
                       decoration-warning="time_status == 'near'"
                       decoration-danger="time_status == 'late'"/>

                <!--                <field name="completed_date"/>-->

            </xpath>

        </field>
    </record>

    <!-- ================= ACTION ================= -->
    <record id="action_helpdesk_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">helpdesk.department</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================= MENU ================= -->

    <menuitem id="menu_helpdesk_department"
              name="Departments"
              parent="menu_helpdesk_priority_root"
              action="action_helpdesk_department"
              sequence="15"/>


    <menuitem id="helpdesk_mgmt.helpdesk_all_ticket_menu"
              name="All Tickets"
              parent="helpdesk_mgmt.helpdesk_ticket_menu"
              groups="department_helpdesk.group_helpdesk_department_manager,department_helpdesk.group_helpdesk_admin_custom"/>

    <menuitem id="helpdesk_mgmt.helpdesk_ticket_config_main_menu"
              name="Configuration"
              parent="helpdesk_mgmt.helpdesk_ticket_main_menu"
              groups="department_helpdesk.group_helpdesk_department_manager,department_helpdesk.group_helpdesk_admin_custom"/>
</odoo>