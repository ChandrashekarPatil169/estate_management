    <!-- FACILITY TAB -->
    <!-- ===================================================== -->

    <record id="view_helpdesk_ticket_form_facility"
            model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.facility</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Facility Details"
                      name="facility_details"
                      invisible="department_type != 'facility'">

                    <!-- ================= Maintenance ================= -->
                    <group string="Maintenance">
                        <field name="maintenance_type_id"/>
                        <field name="severity_id"/>
                        <field name="trade_id"/>
                        <field name="issue_type"/>
                    </group>
                    <!-- ================= Equipment ================= -->
                    <group string="Equipment / Facility Objects" col="2">
                        <field name="facility_asset_id"/>
                        <field name="asset_serial" readonly="1"/>
                        <!--                        <field name="meter_reading"/>-->
                        <field name="warranty_status" readonly="1"/>
                    </group>

                    <!-- ================= Parts / Cost / Closeout ================= -->


                    <!-- PARTS -->
                    <group string="Parts, Cost and Closeout" col="4">

                        <!-- PARTS -->
                        <group string="Parts" colspan="4">

                            <field name="parts_required_ids" colspan="4">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                </list>
                            </field>

                            <field name="parts_issued_ids" colspan="4">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                </list>
                            </field>

                        </group>

                    </group>


                    <!-- COST -->
                    <group string="Cost">
                        <field name="labor_hours"/>
                        <field name="material_cost"/>
                        <field name="labor_cost"/>
                        <field name="other_cost"/>
                        <field name="total_cost" readonly="1"/>
                    </group>

                    <!-- CLOSEOUT -->
                    <group string="Before/After Photo." col="2">

                        <field name="resolution_notes" colspan="2"/>

                        <group string="Before Photos" colspan="2">
                            <field name="before_photo_ids" widget="many2many_binary"/>
                        </group>

                        <group string="After Photos" colspan="2">
                            <field name="after_photo_ids" widget="many2many_binary"/>
                        </group>

                        <group col="2" colspan="2">
                            <field name="signoff_by"/>
                            <field name="signoff_at"/>
                        </group>
                    </group>
                    <!-- ================= Vendor ================= -->
                    <group string="Vendor and Compliance" col="2">
                        <group>
                            <field name="vendor_contact"/>
                            <field name="contract_id"/>
                        </group>

                        <group>
                            <field name="permit_required"/>
                            <field name="permit_id"
                                   invisible="not permit_required"/>
                            <field name="safety_checklist_completed"
                                   invisible="not permit_required"/>
                        </group>

                        <group colspan="2">
                            <!-- FIXED: correct widget -->
                            <field name="attachments_permit" widget="many2many_binary"/>
                        </group>
                    </group>

                </page>
            </xpath>

            <!-- Add extra fields after channel -->
            <xpath expr="//field[@name='channel_id']" position="after">
                <field name="request_title"/>
<!--                <field name="requested_person_id" readonly="1"/>-->
<!--                <field name="req_department_id" readonly="1"/>-->


                <field name="requested_date"/>
<!--                <field name="department_id_main"/>-->
                <field name="department_type"/>
                <field name="manager_id_main" readonly="1"/>
                <!--                <field name="manager_id" groups="helpdesk_mgmt.group_helpdesk_manager"/>-->


                <!--                <field name="assign_to" groups="department_helpdesk.group_helpdesk_department_manager,department_helpdesk.group_helpdesk_admin_custom"/>-->
            </xpath>

            <!-- Hide partner fields -->
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_name']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_email']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

        </field>
    </record>

