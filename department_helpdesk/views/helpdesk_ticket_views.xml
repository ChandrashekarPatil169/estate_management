    <!-- ================= TAT DETAILS ================= -->
    <record id="view_helpdesk_ticket_form_tat"
            model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.tat</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk_mgmt.ticket_view_form"/>
        <field name="arch" type="xml">
            <!-- Insert TAT page after Facility page -->
            <xpath expr="//field[@name='maintenance_type_id']/ancestor::page"
                   position="after">
                <!-- Manager / Admin always see -->
                <page string="Assignment Details"
                      name="tat_details_tab_manager"
                      groups="department_helpdesk.group_helpdesk_department_manager,department_helpdesk.group_helpdesk_admin_custom">

                    <group col="2">
                        <group>
                            <field name="assign_to"/>
                            <field name="assign_date"/>
                            <field name="resolved_date"/>
                            <field name="completed_date"/>
                        </group>

                        <group>
                            <field name="tat_ticket" readonly="1"/>
                            <field name="tat_assignment" readonly="1"/>
                        </group>
                    </group>

                </page>


                <!-- Assigned user sees only their ticket -->
                <page string="Assignment Details"
                      name="tat_details_tab_user"
                      groups="department_helpdesk.group_helpdesk_user_custom"
                      invisible="assign_to != uid">

                    <group col="2">
                        <group>
                            <field name="assign_to"/>
                            <field name="assign_date"/>
                            <field name="resolved_date"/>
                            <field name="completed_date"/>
                        </group>

                        <group>
                            <field name="tat_ticket" readonly="1"/>
                            <field name="tat_assignment" readonly="1"/>
                        </group>
                    </group>

                </page>
            </xpath>
        </field>
    </record>

