<odoo>
    <record id="project_project_timeline" model="ir.ui.view">
        <field name="model">project.project</field>
        <field name="type">timeline</field>
        <field name="arch" type="xml">
            <timeline
                    date_start="planned_start_date"
                    date_stop="planned_end_date"
                    default_group_by="user_id"
                    event_open_popup="true"
            >

                <!-- Required fields -->
                <field name="name"/>
                <field name="user_id"/>
                <field name="planned_start_date"/>
                <field name="planned_end_date"/>
                <field name="expected_end_date"/>
                <field name="project_progress"/>

                <templates>
                    <t t-name="timeline-item">
                        <div class="o_project_timeline_item"
                             style="white-space:nowrap; font-size:13px;">

                            <!-- Project Manager Avatar -->
                            <t t-if="record.user_id">
                                <img
                                        t-att-src="'/web/image/res.users/%s/avatar_128' % record.user_id[0]"
                                        width="16"
                                        height="16"
                                        class="me-1 rounded-circle"
                                        t-att-alt="record.user_id[1]"
                                />
                            </t>

                            <!-- Project Name -->
                            <t t-esc="record.name"/>

                            <!-- Planned Dates -->
                            <t t-if="record.planned_start_date and record.planned_end_date">
                                |
                                Planned Date:
                                <t t-esc="record.planned_start_date.substr(0,10)"/>
                                →
                                <t t-esc="record.planned_end_date.substr(0,10)"/>
                            </t>

                            <!-- Expected Date -->
                            <t t-if="record.expected_end_date">
                                <span class="o_timeline_exp_date" style="margin-left:10px;">
                                    |
                                    Exp:
                                    <t t-esc="record.expected_end_date.substr(0,10)"/>
                                </span>
                            </t>

                            <t t-set="progress" t-value="record.project_progress || 0"/>

                            <t t-set="bar_color"
                               t-value="progress &lt; 30
                                        ? '#dc3545'
                                        : (progress &lt; 70
                                        ? '#f4d03f'
                                        : '#2ecb71')"/>

                            <div style="margin-top:5px; width:200px;">
                                <div style="background:#e9ecef; height:6px; border-radius:4px;">
                                    <div t-att-style="'width:' + progress + '%; height:6px; border-radius:4px; background:' + bar_color + ';'">
                                    </div>
                                </div>
                                <small style="font-size:11px;">
                                    <t t-esc="progress.toFixed(1)"/>%
                                </small>
                            </div>

                        </div>
                    </t>
                </templates>

            </timeline>
        </field>
    </record>

    <record id="project.open_view_project_all" model="ir.actions.act_window">
        <field name="view_mode">kanban,list,form,timeline</field>
    </record>
    <record id="project.open_view_project_all_group_stage" model="ir.actions.act_window">
        <field name="view_mode">kanban,list,form,calendar,activity,timeline</field>
    </record>
</odoo>