<odoo>

    <record id="project.project_project_1" model="project.project">
        <field name="date_start"
               eval="(datetime.datetime.today() - datetime.timedelta(days=5)).strftime('%Y-%m-%d')"/>
        <field name="date"
               eval="(datetime.datetime.today() + datetime.timedelta(days=2)).strftime('%Y-%m-%d')"/>
    </record>

    <record id="project.project_project_2" model="project.project">
        <field name="date_start"
               eval="(datetime.datetime.today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d')"/>
        <field name="date"
               eval="(datetime.datetime.today() + datetime.timedelta(days=10)).strftime('%Y-%m-%d')"/>
    </record>

</odoo>