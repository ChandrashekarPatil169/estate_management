<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_project_rejected" model="mail.template">
            <field name="name">Project Rejected Notification</field>
            <field name="model_id" ref="project.model_project_project"/>

            <!-- ✅ FIX: Keep on one line to avoid linefeed error -->
            <field name="subject">Project Rejected: {{ object.name }}</field>

            <!-- ✅ FIX: Format email_from strictly on one line -->
            <field name="email_from">{{ (user.email_formatted or user.email or 'noreply@example.com').strip() }}</field>

            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-size: 13px;">
                    <p>Hello,</p>
                    <p>The project <b><t t-out="object.name"/></b> has been <b>rejected</b>.</p>
                    <ul>
                        <li><b>Rejected By:</b> <t t-out="ctx.get('rejected_by') or user.name"/></li>
                        <!-- Ensure 'reject_reason' matches the field in your project model -->
                        <li><b>Reason:</b> <t t-out="object.reject_reason or 'N/A'"/></li>
                    </ul>
                    <p>
                        <a t-attf-href="/web#id={{ object.id }}&amp;model=project.project&amp;view_type=form"
                           style="padding: 8px 16px; background-color: #875A7B; color: #fff; text-decoration: none; border-radius: 5px;">
                            Open Project
                        </a>
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>















