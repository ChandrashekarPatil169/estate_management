<odoo>
    <record id="project_project_kanban_settings_bottom" model="ir.ui.view">
        <field name="name">project.project.kanban.settings.bottom</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">

            <!-- Add settings icon at bottom right -->
            <xpath expr="//t[@t-name='card']//footer/div[@class='d-flex ms-auto align-items-center']" position="inside">

                <a type="open" title="Settings" class="ms-2">
                    <i class="fa fa-cog" style="font-size:18px;color:#875A7B;"/>
                </a>

            </xpath>

        </field>
    </record>
</odoo>