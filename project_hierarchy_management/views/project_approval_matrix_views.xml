<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree -->
    <record id="view_project_approval_matrix_tree" model="ir.ui.view">
        <field name="name">project.approval.matrix.tree</field>
        <field name="model">project.approval.matrix</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_project_approval_matrix_form" model="ir.ui.view">
        <field name="name">project.approval.matrix.form</field>
        <field name="model">project.approval.matrix</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_project_approval_matrix" model="ir.actions.act_window">
        <field name="name">Project Approval Matrix</field>
        <field name="res_model">project.approval.matrix</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_project_approval_matrix"
              name="Approval Matrix"
              parent="project.menu_project_config"
              action="action_project_approval_matrix"
              groups="base.group_system"/>

</odoo>
