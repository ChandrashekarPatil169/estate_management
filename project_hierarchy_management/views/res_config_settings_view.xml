<odoo>
    <data>
        <record id="view_project_config_settings" model="ir.ui.view">
            <field name="name">project.config.settings.inherit</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="project.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form//app[@name='project']" position="inside">
                    <block title="Project Creation Control">
                        <setting help="Select users who are allowed to create projects">
                            <field name="project_creator_user_ids" widget="many2many_tags"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
