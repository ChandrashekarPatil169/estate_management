<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_project_reject_wizard_form" model="ir.ui.view">
        <field name="name">project.reject.wizard.form</field>
        <field name="model">project.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Project">
                <sheet>
                    <group>
                        <field name="project_id"/>
                        <field name="reject_reason"
                               placeholder="Enter the reason for rejection..."/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_confirm_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
