<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- =================== SOFTWARE ASSET VIEWS =================== -->

    <!-- list View -->
    <record id="view_software_asset_list" model="ir.ui.view">
        <field name="name">software.asset.list</field>
        <field name="model">software.asset</field>
        <field name="arch" type="xml">
            <list string="Software Assets">
                <field name="name"/>
                <field name="warehouse_id"/>
                <field name="version"/>
                <field name="vendor"/>
                <field name="license_type_id"/>

                <field name="assigned_to"/>
                <field name="expiry_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_software_asset_form" model="ir.ui.view">
        <field name="name">software.asset.form</field>
        <field name="model">software.asset</field>
        <field name="arch" type="xml">
            <form string="Software Asset">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_renewals"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-refresh">
                            <field name="renewal_count"
                                   widget="statinfo"
                                   string="Renewal History"/>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="warehouse_id"
                               options="{'no_create': True}"/>
                        <field name="vendor"/>
                        <field name="version"/>
                        <field name="license_key"/>
                        <field name="license_type_id"/>

                        <field name="purchase_date"/>
                        <field name="expiry_date"/>
                        <field name="assigned_to"/>
                    </group>
                    <notebook>
                        <page string="Installations">
                            <field name="installation_ids">
                                <list editable="bottom">
                                    <field name="model_id"/>
                                    <field name="device"/>
                                    <field name="installed_by"/>
                                    <field name="install_date"/>
                                    <field name="remarks"/>
                                </list>
                            </field>
                        </page>
                        <page string="Renewal History">
                            <field name="renewal_ids">
                                <list editable="bottom">
                                    <field name="renewal_date"/>
                                    <field name="renewed_by"/>
                                    <field name="amount"/>
                                    <field name="remarks"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_software_asset_pivot" model="ir.ui.view">
        <field name="name">software.asset.pivot</field>
        <field name="model">software.asset</field>
        <field name="arch" type="xml">
            <pivot string="Software Asset Analysis">

                <!-- Measure -->
<!--                <field name="id" type="measure"/>-->

                <!-- Rows -->
                <field name="warehouse_id" type="row"/>
                <field name="license_type_id" type="row"/>

                <!-- Columns -->
                <field name="assigned_to" type="col"/>

                <!-- Time -->
                <field name="expiry_date" interval="month" type="col"/>

            </pivot>
        </field>
    </record>

    <record id="view_software_asset_graph" model="ir.ui.view">
        <field name="name">software.asset.graph</field>
        <field name="model">software.asset</field>
        <field name="arch" type="xml">
            <graph string="Software Distribution" type="bar">

                <field name="warehouse_id"/>
                <field name="id" type="measure"/>

            </graph>
        </field>
    </record>

    <record id="view_software_renewal_list" model="ir.ui.view">
        <field name="name">software.renewal.list</field>
        <field name="model">software.renewal</field>
        <field name="arch" type="xml">
            <list>
                <field name="software_id"/>
                <field name="renewal_date"/>
                <field name="renewed_by"/>
                <field name="amount"/>
            </list>
        </field>
    </record>
    <record id="view_software_renewal_form" model="ir.ui.view">
        <field name="name">software.renewal.form</field>
        <field name="model">software.renewal</field>
        <field name="arch" type="xml">
            <form string="Renewal History">
                <sheet>
                    <group>
                        <group>
                            <field name="software_id"/>
                            <field name="renewal_date"/>
                            <field name="renewed_by"/>
                        </group>
                        <group>
                            <field name="amount"/>
                        </group>
                    </group>
                    <group string="Remarks">
                        <field name="remarks"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_software_license_type_list" model="ir.ui.view">
        <field name="name">software.license.type.list</field>
        <field name="model">software.license.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>
    <record id="view_software_license_type_form" model="ir.ui.view">
        <field name="name">software.license.type.form</field>
        <field name="model">software.license.type</field>
        <field name="arch" type="xml">
            <form string="Software License Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                    <group string="Description">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_software_license_type_pivot" model="ir.ui.view">
        <field name="name">software.license.type.pivot</field>
        <field name="model">software.license.type</field>
        <field name="arch" type="xml">
            <pivot string="License Type Analysis">

                <!-- REQUIRED -->
<!--                <field name="id" type="measure"/>-->

                <!-- Group -->
                <field name="name" type="row"/>

            </pivot>
        </field>
    </record>

    <record id="view_software_license_type_graph" model="ir.ui.view">
        <field name="name">software.license.type.graph</field>
        <field name="model">software.license.type</field>
        <field name="arch" type="xml">
            <graph string="License Type Distribution" type="bar">

                <field name="name"/>
                <field name="id" type="measure"/>

            </graph>
        </field>
    </record>


    <!-- Action -->
    <record id="action_software_asset" model="ir.actions.act_window">
        <field name="name">Software Assets</field>
        <field name="res_model">software.asset</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_software_asset"
              name="Software Assets"
              parent="custom_inventory_menu"
              action="action_software_asset"/>

</odoo>