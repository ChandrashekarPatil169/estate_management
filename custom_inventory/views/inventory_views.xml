    <template id="report_custom_inventory_template"
              t-name="custom_inventory.report_custom_inventory_template">

        <t t-call="web.html_container">

            <!-- SINGLE PAGE -->
            <div style="
            width:100%;
            page-break-after:avoid;
            page-break-before:avoid;
        ">

                <t t-foreach="docs" t-as="o">

                    <!-- EACH ITEM -->
                    <div style="
                    width:35mm;
                    height:40mm;
                    margin:5mm auto;
                    padding:0;
                    box-sizing:border-box;
                    display:block;
                ">

                        <!-- ASSET TAG -->
                        <div style="
                        height:5mm;
                        font-size:7px;
                        font-weight:bold;
                        text-align:center;
                        margin:0;
                        padding:0;
                    ">
                            <span t-field="o.asset_tag"/>
                        </div>

                        <!-- QR -->
                        <img t-if="o.qr_code"
                             t-att-src="'data:image/png;base64,%s' % (o.qr_code.decode() if isinstance(o.qr_code, bytes) else o.qr_code)"
                             style="
                            width:35mm;
                            height:35mm;
                            display:block;
                            margin:0;
                            padding:0;
                         "/>

                    </div>

                </t>

            </div>

        </t>

    </template>
    <record id="view_users_form_inherit_warehouse" model="ir.ui.view">
        <field name="name">res.users.form.warehouse.tab</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <!-- Add new tab inside notebook -->
            <xpath expr="//notebook" position="inside">

                <page string="Warehouses Access">

                    <group>
                        <field name="warehouse_exec_ids" widget="many2many_tags"/>
                    </group>

                    <group>
                        <field name="warehouse_manager_ids" widget="many2many_tags"/>
                    </group>

                </page>
            </xpath>

        </field>
    </record>


</odoo>