    <!-- ===================================================== -->
    <!-- 🔹 TICKET LIST VIEW -->
    <!-- ===================================================== -->
    <record id="view_ticket_list" model="ir.ui.view">
        <field name="model">ticket.ticket</field>
        <field name="arch" type="xml">
            <list string="Tickets">

                <field name="name"/>
                <field name="subject"/>
                <field name="priority"/>
                <field name="status"/>

                <field name="inventory_id"/>
                <field name="software_id"/>

                <field name="asset_tag"/>
                <field name="product_name_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>

                <field name="reported_by"/>
                <field name="assigned_to"/>

                <field name="assign_date"/>
                <field name="resolve_date"/>
                <field name="close_date"/>

                <field name="cost"/>

            </list>
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- 🔹 TICKET FORM VIEW -->
    <!-- ===================================================== -->
    <record id="view_ticket_form" model="ir.ui.view">
        <field name="model">ticket.ticket</field>
        <field name="arch" type="xml">
            <form string="Support Ticket">

                <!-- HEADER BUTTONS -->
                <header>

                    <button name="action_resolve"
                            type="object"
                            string="Resolve"
                            class="btn-primary"
                            invisible="status == 'resolved' or status == 'closed'"/>

                    <button name="action_close"
                            type="object"
                            string="Close"
                            class="btn-danger"
                            invisible="status == 'closed'"/>

                </header>

                <sheet>

                    <!-- TITLE -->
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="subject"/>
                    </group>

                    <!-- STATUS & PRIORITY -->
                    <group>
                        <field name="priority"/>
                        <field name="status"/>
                    </group>

                    <!-- DESCRIPTION -->
                    <group>
                        <field name="description"/>
                    </group>

                    <!-- ASSET LINK -->
                    <group string="Related Asset">
                        <field name="inventory_id"/>
                        <field name="software_id"/>
                    </group>

                    <!-- AUTO DETAILS -->
                    <group string="Asset Details">
                        <field name="asset_tag" readonly="1"/>
                        <field name="asset_type_id" readonly="1"/>
                        <field name="asset_category_id" readonly="1"/>
                        <field name="product_name_id" readonly="1"/>
                        <field name="brand_id" readonly="1"/>
                        <field name="model_id" readonly="1"/>
                    </group>

                    <!-- ASSIGNMENT -->
                    <group string="Assignment">
                        <field name="reported_by"/>
                        <field name="assigned_to"/>
                    </group>

                    <!-- DATES -->
                    <group string="Timeline">
                        <field name="assign_date" readonly="1"/>
                        <field name="resolve_date" readonly="1"/>
                        <field name="close_date" readonly="1"/>
                    </group>

                    <!-- RESOLUTION -->
                    <group string="Resolution">
                        <field name="resolution_notes"/>
                        <field name="cost"/>
                    </group>

                    <chatter/>

                </sheet>
            </form>
        </field>
    </record>


