<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- CATEGORY -->
    <record id="coffee_hierarchy_category" model="ir.module.category">
        <field name="name">Coffee Management</field>
        <field name="sequence">40</field>
    </record>

    <!-- PRIVILEGE -->
    <record id="privilege_coffee_management" model="res.groups.privilege">
        <field name="name">Coffee Hierarchy</field>
        <field name="category_id" ref="estate_coffee_management.coffee_hierarchy_category"/>
    </record>

    <!-- GROUPS -->

    <record id="group_coffee_user" model="res.groups">
        <field name="name">Coffee User</field>
        <field name="privilege_id" ref="estate_coffee_management.privilege_coffee_management"/>
    </record>

    <record id="group_coffee_employee" model="res.groups">
        <field name="name">Coffee Employee</field>
        <field name="privilege_id" ref="estate_coffee_management.privilege_coffee_management"/>
        <field name="implied_ids" eval="[(4, ref('estate_coffee_management.group_coffee_user'))]"/>
    </record>

    <record id="group_coffee_manager" model="res.groups">
        <field name="name">Coffee Manager</field>
        <field name="privilege_id" ref="estate_coffee_management.privilege_coffee_management"/>
        <field name="implied_ids" eval="[(4, ref('estate_coffee_management.group_coffee_employee'))]"/>
    </record>

    <record id="group_coffee_general_manager" model="res.groups">
        <field name="name">Coffee General Manager</field>
        <field name="privilege_id" ref="estate_coffee_management.privilege_coffee_management"/>
        <field name="implied_ids" eval="[(4, ref('estate_coffee_management.group_coffee_manager'))]"/>
    </record>

</odoo>




