<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- GLOBAL RULE TEMPLATE -->

    <!-- MODEL LIST -->

    <record id="estate_coffee_ingredient_rw_rule" model="ir.rule">
        <field name="name">Estate Coffee Ingredient Secure Access</field>
        <field name="model_id" ref="model_estate_coffee_ingredient"/>
        <field name="domain_force">
            ['|','|',
            ('create_uid', '=', user.id),
            ('message_partner_ids', 'in', [user.partner_id.id]),
            '&amp;',
            ('create_uid', '!=', 1),
            ('create_uid', 'child_of', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('estate_coffee_management.group_coffee_user')),
                                   (4, ref('estate_coffee_management.group_coffee_employee')),
                                   (4, ref('estate_coffee_management.group_coffee_manager')),
                                   (4, ref('estate_coffee_management.group_coffee_general_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="True"/>
    </record>

