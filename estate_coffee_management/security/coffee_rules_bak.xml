<odoo>
    <!-- Managers: Full Access to all models -->
    <record id="rule_coffee_manager_full_ingredient" model="ir.rule">
        <field name="name">Coffee Manager Full Access - Ingredient</field>
        <field name="model_id" ref="model_estate_coffee_ingredient"/>
        <field name="groups" eval="[(4, ref('estate_coffee_management.group_coffee_manager'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>

    <record id="rule_coffee_manager_full_building_stock" model="ir.rule">
        <field name="name">Coffee Manager Full Access - Building Stock</field>
        <field name="model_id" ref="model_building_stock"/>
        <field name="groups" eval="[(4, ref('estate_coffee_management.group_coffee_manager'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>

    <record id="rule_coffee_manager_full_coffee_machine" model="ir.rule">
