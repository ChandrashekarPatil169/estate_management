    </record>

    <!-- Users: Only records they follow -->
    <record id="rule_coffee_user_followers_ingredient" model="ir.rule">
        <field name="name">Users Access if Follower - Ingredient</field>
        <field name="model_id" ref="model_estate_coffee_ingredient"/>
        <field name="groups" eval="[(4, ref('estate_coffee_management.group_coffee_user'))]"/>
        <field name="domain_force">[('message_follower_ids.partner_id','in',[user.partner_id.id])]</field>
    </record>

