<odoo>
    <record id="view_coffee_machine_list" model="ir.ui.view">
        <field name="name">coffee.machine.list</field>
        <field name="model">coffee.machine</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="building_id"/>
            </list>
        </field>
    </record>

    <record id="view_coffee_machine_form" model="ir.ui.view">
        <field name="name">coffee.machine.form</field>
        <field name="model">coffee.machine</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="building_id"/>

                    </group>
                    <notebook>
                        <page string="Machine Stock" invisible="1">
                            <field name="machine_stock_ids">
                                <list>
                                    <field name="ingredient_id"/>
                                    <field name="quantity"/>
                                    <field name="refill_date"/>
                                    <field name="employee_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>

            </form>
        </field>
    </record>
    <!-- Pivot View for Coffee Machine -->
    <record id="view_coffee_machine_pivot" model="ir.ui.view">
        <field name="name">coffee.machine.pivot</field>
        <field name="model">coffee.machine</field>
        <field name="arch" type="xml">
            <pivot string="Coffee Machine Analysis">

                <!-- Rows -->
                <field name="building_id" type="row"/>
                <field name="name" type="row"/>

                <!-- Columns -->
                <field name="create_date" type="col"/>

                <!-- Measures -->
                <!--            <field name="id" type="measure"/>-->

            </pivot>
        </field>
    </record>


    <record id="action_coffee_machine" model="ir.actions.act_window">
        <field name="name">Coffee Machines</field>
        <field name="res_model">coffee.machine</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="view_id" ref="view_coffee_machine_list"/>
    </record>
</odoo>
