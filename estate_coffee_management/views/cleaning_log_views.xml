<odoo>
    <record id="view_cleaning_log_list" model="ir.ui.view">
        <field name="name">cleaning.log.list</field>
        <field name="model">cleaning.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="machine_id"/>
                <field name="building_id"/>
                <field name="employee_id"/>
                <field name="date_time"/>
                <field name="remarks"/>
            </list>
        </field>
    </record>

    <record id="view_cleaning_log_form" model="ir.ui.view">
        <field name="name">cleaning.log.form</field>
        <field name="model">cleaning.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="machine_id"/>
                        <field name="building_id"/>
                        <field name="employee_id"/>
                        <field name="date_time"/>
                        <field name="remarks"/>
                    </group>


                </sheet>
                <chatter/>

            </form>
        </field>
    </record>


    <record id="action_cleaning_log" model="ir.actions.act_window">
        <field name="name">Cleaning Logs</field>
        <field name="res_model">cleaning.log</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="view_id" ref="view_cleaning_log_list"/>
    </record>
</odoo>
