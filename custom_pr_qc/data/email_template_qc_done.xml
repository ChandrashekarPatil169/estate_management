<odoo>
    <data>
        <record id="email_template_qc_done" model="mail.template">
            <field name="name">QC Completed Notification</field>
            <!-- Ensure this reference matches your custom module's model ID -->
            <field name="model_id" ref="material_purchase_requisition.model_material_purchase_requisition"/>
            <field name="subject">Quality Check Completed</field>

            <field name="email_from">{{ object.company_id.email }}</field>

            <!-- Usually sent to the requester or creator -->
            <field name="email_to"></field>

            <field name="auto_delete" eval="False"/>

            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Hello,
                        <br/><br/>
                        ✅ Quality Check has been <b>completed</b> for the following:
                        <br/><br/>
                        <ul>
                            <li><b>PR:</b> <t t-out="object.name"/></li>
                            <li><b>PO:</b> <t t-out="ctx.get('po_name')"/></li>
                            <li><b>Receipt:</b> <t t-out="ctx.get('picking_name')"/></li>
                        </ul>
                        <br/>
                        <b>Products Received:</b>
                        <br/>
                        <t t-out="ctx.get('product_list')"/>
                        <br/><br/>
                        All quality checks have been successfully completed and materials are received.
                        <br/><br/>
                        Regards,<br/>
                        <t t-out="object.company_id.name"/>
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>
