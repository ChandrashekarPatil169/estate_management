<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qc_rejection_wizard_form" model="ir.ui.view">
        <field name="name">qc.rejection.wizard.form</field>
        <field name="model">qc.rejection.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Quality Check">
                <group>
                    <field name="reason" placeholder="Explain why this failed..." required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_rejection" string="Confirm Reject" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
