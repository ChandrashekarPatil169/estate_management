<odoo>
    <!-- Define the tree (list) view for custom location -->
    <record id="view_tree_custom_location" model="ir.ui.view">
        <field name="name">custom.location.tree</field>
        <field name="model">custom.location</field>
        <field name="arch" type="xml">
            <list string="Locations">
                <field name="name"/>
                <field name="street"/>
                <field name="street2"/>
                <field name="city"/>
                <field name="state"/>
                <field name="country"/>
                <field name="pincode"/>
            </list>
        </field>
    </record>

    <!-- Define the form view for custom location -->
    <record id="view_form_custom_location" model="ir.ui.view">
        <field name="name">custom.location.form</field>
        <field name="model">custom.location</field>
        <field name="arch" type="xml">
            <form string="Location">
                <header>
                    <widget name="fetch_location"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="map_url" readonly="1"/>
                        <field name="street"/>
                        <field name="street2"/>
                        <field name="city"/>
                        <field name="state"/>
                        <field name="country"/>
                        <field name="pincode"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Define an action to show the list of custom locations -->
    <record id="action_custom_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">custom.location</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <!-- Add the action to the HR menu (under hr.menu_hr_root) -->
    <menuitem id="menu_custom_location"
              name="Custom Locations"
              parent="hr.menu_hr_root"
              sequence="100"/>
    <menuitem id="menu_custom_location_1"
              name="Custom Locations"
              parent="menu_custom_location"
              action="action_custom_location"
              sequence="2"/>
</odoo>