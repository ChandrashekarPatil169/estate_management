<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- CATEGORY -->
    <record id="estate_hierarchy_category" model="ir.module.category">
        <field name="name">Estate Management</field>
        <field name="sequence">20</field>
    </record>

    <!-- PRIVILEGE (The "Container" for Odoo 19) -->
    <record id="privilege_estate_management" model="res.groups.privilege">
        <field name="name">Estate Hierarchy</field>
        <field name="category_id" ref="estate_hierarchy_category"/>
    </record>

    <!-- GROUPS -->
    <record id="group_estate_user" model="res.groups">
        <field name="name">Estate User</field>
        <field name="privilege_id" ref="privilege_estate_management"/>
    </record>

    <record id="group_estate_employee" model="res.groups">
        <field name="name">Estate Employee</field>
        <field name="privilege_id" ref="privilege_estate_management"/>
        <field name="implied_ids" eval="[(4, ref('group_estate_user'))]"/>
    </record>

    <record id="group_estate_manager" model="res.groups">
        <field name="name">Estate Manager</field>
        <field name="privilege_id" ref="privilege_estate_management"/>
        <field name="implied_ids" eval="[(4, ref('group_estate_employee'))]"/>
    </record>

    <record id="group_estate_general_manager" model="res.groups">
        <field name="name">Estate General Manager</field>
        <field name="privilege_id" ref="privilege_estate_management"/>
        <field name="implied_ids" eval="[(4, ref('group_estate_manager'))]"/>
    </record>
</odoo>
