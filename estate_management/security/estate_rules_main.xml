    <!-- PROPERTY -->
    <record id="estate_property_rw_rule" model="ir.rule">
        <field name="name">Property Secure Access</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">
            ['|','|',
            ('create_uid', '=', user.id),
            ('message_partner_ids', 'in', [user.partner_id.id]),
            '&amp;',
            ('create_uid', '!=', 1),
            ('create_uid', 'child_of', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('estate_management.group_estate_user')),
                                   (4, ref('estate_management.group_estate_employee')),
                                   (4, ref('estate_management.group_estate_manager')),
                                   (4, ref('estate_management.group_estate_general_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="True"/>
    </record>

