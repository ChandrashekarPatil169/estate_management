<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="email_template_building_payment_reminder" model="mail.template">
            <field name="name">Building Payment Reminder</field>
            <field name="model_id" ref="estate_management.model_estate_building_payment"/>
            <field name="subject">
                Building Payment Reminder - {{ object.name }}
            </field>
            <field name="use_default_to" eval="True"/>

            <field name="body_html" type="html">
                <div style="margin:0px; padding:0px; font-family:'Segoe UI', Arial, sans-serif;">

                    <p style="font-size:13px; color:#495057;">
                        Hello {{ ctx.get('recipient_name') or 'Resident' }},
                        <br/>
                        <br/>

                        This is a reminder that the building payment
                        <strong>{{ object.name }}</strong>
                        is due on
                        <strong>{{ object.due_date }}</strong>.
                        <br/>
                        <br/>
                    </p>

                    <table border="0" cellpadding="5" cellspacing="0"
                           style="background-color:#f8f9fa;
                                  border:1px solid #dee2e6;
                                  width:100%;
                                  max-width:400px;
                                  border-radius:4px;">
                        <tr>
                            <td style="color:#6c757d;">Payment Reference:</td>
                            <td style="font-weight:600;">
                                {{ object.name }}
                            </td>
                        </tr>
                        <tr>
                            <td style="color:#6c757d;">Amount Due:</td>
                            <td style="font-weight:600; color:#d9534f;">
                                {{ object.amount }}
                            </td>
                        </tr>
                    </table>

                    <br/>

                    <p style="font-size:13px; color:#495057;">
                        Please ensure your payment is processed by the due date to avoid late fees.
                        <br/>
                        <br/>

                        Regards,
                        <br/>
                        <strong>{{ object.company_id.name }}</strong>
                    </p>

                </div>
            </field>

        </record>

        <record id="email_template_unit_payment_reminder" model="mail.template">
            <field name="name">Unit Payment Reminder</field>
            <field name="model_id" ref="estate_management.model_estate_unit_payment"/>
            <field name="subject">
                Unit Payment Reminder - {{ object.name }}
            </field>
            <field name="use_default_to" eval="True"/>

            <field name="body_html" type="html">
                <div style="margin:0px; padding:0px; font-family:'Segoe UI', Arial, sans-serif;">

                    <p style="font-size:13px; color:#495057;">
                        Hello {{ ctx.get('recipient_name') or 'Resident' }},
                        <br/>
                        <br/>

                        This is a reminder that your unit payment
                        <strong>{{ object.name }}</strong>
                        is due on
                        <strong>{{ object.due_date }}</strong>.
                        <br/>
                        <br/>
                    </p>

                    <table border="0" cellpadding="6" cellspacing="0"
                           style="background-color:#f8f9fa;
                                  border:1px solid #dee2e6;
                                  width:100%;
                                  max-width:450px;
                                  border-radius:4px;">

                        <tr>
                            <td style="color:#6c757d;">Unit:</td>
                            <td style="font-weight:600;">
                                {{ object.unit_id.display_name }}
                            </td>
                        </tr>

                        <tr>
                            <td style="color:#6c757d;">Payment For:</td>
                            <td style="font-weight:600;">
                                {{ object.product_id.name }}
                            </td>
                        </tr>

                        <tr>
                            <td style="color:#6c757d;">Amount Due:</td>
                            <td style="font-weight:600; color:#d9534f;">
                                {{ object.amount }}
                            </td>
                        </tr>

                    </table>

                    <br/>

                    <p style="font-size:13px; color:#495057;">
                        Please ensure the payment is completed before the due date to avoid penalties.
                        <br/>
                        <br/>

                        Regards,
                        <br/>
                        <strong>{{ object.company_id.name }}</strong>
                    </p>

                </div>
            </field>

        </record>

    </data>
</odoo>

