<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Farm Task list View -->
    <record id="view_farm_task_list" model="ir.ui.view">
        <field name="name">estate.farm.task.list</field>
        <field name="model">estate.farm.task</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="farm_id"/>
                <field name="crop_id"/>
                <field name="livestock_id"/>
                <field name="assigned_to"/>
                <field name="priority"/>
                <field name="status"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <!-- Farm Task Form View -->
    <record id="view_farm_task_form" model="ir.ui.view">
        <field name="name">estate.farm.task.form</field>
        <field name="model">estate.farm.task</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="farm_id"/>
                        <field name="crop_id"/>
                        <field name="livestock_id"/>
                        <field name="assigned_to"/>
                        <field name="priority"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="status"/>
                    </group>

                    <group string="Resources &amp; Notes">
                        <field name="resources_used"/>
                        <field name="cost_estimate"/>
                        <field name="notes"/>
                        <field name="iot_integration"/>
                        <field name="environmental_metrics"/>
                    </group>

                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Farm Task Pivot -->
    <record id="view_farm_task_pivot" model="ir.ui.view">
        <field name="name">estate.farm.task.pivot</field>
        <field name="model">estate.farm.task</field>
        <field name="arch" type="xml">
            <pivot string="Farm Task Analysis">

                <!-- ROWS -->
                <field name="farm_id" type="row"/>
                <field name="crop_id" type="row"/>
                <field name="livestock_id" type="row"/>
                <field name="assigned_to" type="row"/>
                <field name="priority" type="row"/>
                <field name="status" type="row"/>

                <!-- TIME -->
                <field name="start_date" interval="month" type="col"/>
                <field name="end_date" interval="month" type="col"/>

                <!-- MEASURES -->
                <field name="cost_estimate" type="measure"/>
<!--                <field name="id" type="measure"/>-->

            </pivot>
        </field>
    </record>

    <!-- Farm Task Action -->
    <record id="action_farm_task" model="ir.actions.act_window">
        <field name="name">Farm Tasks</field>
        <field name="res_model">estate.farm.task</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

    <!-- Farm Task Menu -->
    <menuitem id="menu_farm_task" name="Farm Tasks" parent="menu_farm" action="action_farm_task" sequence="4"/>
</odoo>
