    <!-- Form View -->
    <record id="view_crop_name_form" model="ir.ui.view">
        <field name="name">estate.crop.name.form</field>
        <field name="model">estate.crop.name</field>
        <field name="arch" type="xml">
            <form string="Crop Name">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="haction_open_fertilizers"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-leaf">
                            <field name="fertilizer_count" widget="statinfo"/>
                        </button>

                        <button name="haction_open_chemicals"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-flask">
                            <field name="chemical_count" widget="statinfo"/>
                        </button>


                        <button name="haction_open_varieties"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-leaf">
                            <field name="variety_count" widget="statinfo"/>
                        </button>

                        <button name="haction_open_diseases"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-bug">
                            <field name="disease_count" widget="statinfo"/>
                        </button>

                    </div>

                    <group>
                        <field name="name"/>
                        <!--                        <field name="variety"/>-->
                        <field name="code"/>
                        <field name="cycle_type"/>
                        <field name="irrigation_required"/>
                        <field name="well_id" invisible="not irrigation_required"/>
                        <field name="motor_pump_id" invisible="not irrigation_required"/>

                        <field name="expected_yield"/>
                        <field name="actual_yield"/>
                        <field name="quality_grade"/>
                        <field name="storage_location_id"/>
                        <field name="disease_history"/>
                    </group>
                    <notebook>
                        <page string="Related Details">
                            <group>
                                <field name="variety_ids"
                                       widget="many2many_tags"
                                       context="{'default_crop_name_id': id}"/>
                            </group>
                            <group>

                                <field name="disease_ids"
                                       widget="many2many_tags"
                                       context="{'default_crop_name_id': id}"/>

                            </group>
                            <group>

                                <field name="fertilizer_ids" widget="many2many_tags"
                                       context="{'default_crop_name_id': id}"/>
                            </group>
                            <group>

                                <field name="chemical_ids" widget="many2many_tags"
                                       context="{'default_crop_name_id': id}"/>
                            </group>

                        </page>


                    </notebook>
                </sheet>


            </form>
        </field>
    </record>

