<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- UNIT PAYMENT CRON -->
        <record id="ir_cron_unit_payment_reminder" model="ir.cron">
            <field name="name">Unit Payment Reminder</field>
            <field name="model_id" ref="model_estate_unit_payment"/>
            <field name="state">code</field>
            <field name="code">model._cron_unit_payment_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- BUILDING PAYMENT CRON -->
        <record id="ir_cron_building_payment_reminder" model="ir.cron">
            <field name="name">Building Payment Reminder</field>
            <field name="model_id" ref="model_estate_building_payment"/>
            <field name="state">code</field>
            <field name="code">model._cron_building_payment_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>