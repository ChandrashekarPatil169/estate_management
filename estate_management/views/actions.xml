        <record id="view_unit_type_list" model="ir.ui.view">
        <field name="name">estate.unit.type.list</field>
        <field name="model">estate.unit.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_unit_type_form" model="ir.ui.view">
        <field name="name">estate.unit.type.form</field>
        <field name="model">estate.unit.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_unit_type" model="ir.actions.act_window">
        <field name="name">Unit Types</field>
        <field name="res_model">estate.unit.type</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>


    <record id="view_building_payment_form" model="ir.ui.view">
        <field name="name">estate.building.payment.form</field>
        <field name="model">estate.building.payment</field>
        <field name="arch" type="xml">
            <form>

                <sheet>

                    <!-- ===== HEADER INFO ===== -->
                    <group string="Payment Information">
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="building_id"/>
                            <field name="property_id"/>
                            <field name="product_id"/>
                        </group>

                        <group>
                            <field name="amount" readonly="amount_locked"/>
                            <field name="due_date" readonly="due_date_locked"/>
                            <field name="amount_locked" widget="boolean_toggle"/>
                            <field name="due_date_locked" widget="boolean_toggle"/>
                            <field name="recurring_payment" widget="boolean_toggle"/>
                            <field name="recurring_start_date"
                                   invisible="recurring_payment == False"/>

                            <field name="recurring_end_date"
                                   invisible="recurring_payment == False"/>
                            <!--                            <field name="payment_date"/>-->
                        </group>
                        <group string="Meter Details">
                            <field name="meter_start_reading"/>
                            <field name="meter_end_reading"/>
                            <field name="meter_consumed" readonly="1"/>
                        </group>
                        <group string="Payment Completion">
                            <group>
                                <field name="payment_done_date"/>
                                <field name="payment_method_id"/>
                            </group>
                            <group>
                                <field name="receipt_number"/>
                            </group>
                        </group>
                        <group string="Additional Details">
                            <field name="description"/>
                            <field name="service_billing_date"/>
                        </group>
                    </group>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>
    <!-- ================================================= -->
    <!-- BUILDING PAYMENT LIST VIEW -->
    <!-- ================================================= -->
    <record id="view_building_payment_list" model="ir.ui.view">
        <field name="name">estate.building.payment.list</field>
        <field name="model">estate.building.payment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="building_id"/>
                <field name="property_id"/>
                <field name="product_id"/>
                <field name="amount"/>
                <!--                <field name="payment_date"/>-->
                <field name="due_date"/>
                <field name="payment_done_date"/>
                <field name="meter_start_reading"/>
                <field name="meter_end_reading"/>
                <field name="meter_consumed"/>
                <field name="receipt_number"/>
                <field name="description" optional="hide"/>
                <field name="service_billing_date" optional="show"/>
            </list>
        </field>
    </record>
    <record id="view_estate_building_payment_pivot" model="ir.ui.view">
        <field name="name">estate.building.payment.pivot</field>
        <field name="model">estate.building.payment</field>
        <field name="arch" type="xml">
            <pivot string="Building Payment Analysis">

                <!-- ROW GROUPS -->
                <field name="building_id" type="row"/>
                <field name="property_id" type="row"/>
                <field name="product_id" type="row"/>
                <field name="payment_method_id" type="row"/>
                <field name="recurring_payment" type="row"/>

                <!-- TIME -->
                <field name="due_date" interval="month" type="col"/>
                <field name="payment_done_date" interval="month" type="col"/>

                <!-- MEASURES -->
                <field name="amount" type="measure"/>
                <field name="meter_consumed" type="measure"/>

            </pivot>
        </field>
    </record>
       <record id="action_building_payment" model="ir.actions.act_window">
