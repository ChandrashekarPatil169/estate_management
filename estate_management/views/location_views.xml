<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_location_list" model="ir.ui.view">
        <field name="name">estate.location.list</field>
        <field name="model">estate.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
                <field name="hcount_property" optional="show"/>
                <field name="hcount_building" optional="show"/>
                <field name="hcount_unit" optional="show"/>

                <!-- OPTIONAL -->
                <field name="hcount_floor" optional="hide"/>
                <field name="hcount_room" optional="hide"/>
                <field name="hcount_table" optional="hide"/>
                <field name="hcount_farm" optional="hide"/>
            </list>
        </field>
    </record>


    <!-- ================================================= -->
    <!-- LOCATION FORM VIEW -->
    <!-- ================================================= -->
    <record id="view_location_form" model="ir.ui.view">
        <field name="name">estate.location.form</field>
        <field name="model">estate.location</field>
        <field name="arch" type="xml">
            <form>

                <sheet>

                    <!-- ================= SMART BUTTONS ================= -->
                    <div class="oe_button_box" name="button_box">

                        <button name="haction_open_properties"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-building">
                            <field name="hcount_property"
                                   widget="statinfo"
                                   string="Properties"/>
                        </button>

                        <button name="haction_open_buildings"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-building">
                            <field name="hcount_building"
                                   widget="statinfo"
                                   string="Buildings"/>
                        </button>

                        <button name="haction_open_floors"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-home">
                            <field name="hcount_floor"
                                   widget="statinfo"
                                   string="Floors"/>
                        </button>

                        <button name="haction_open_units"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-home">
                            <field name="hcount_unit"
                                   widget="statinfo"
                                   string="Units"/>
                        </button>

                        <button name="haction_open_rooms"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-th-large">
                            <field name="hcount_room"
                                   widget="statinfo"
                                   string="Rooms"/>
                        </button>

                        <button name="haction_open_tables"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-table">
                            <field name="hcount_table"
                                   widget="statinfo"
                                   string="Tables"/>
                        </button>

                        <button name="haction_open_farms"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-leaf">
                            <field name="hcount_farm"
                                   widget="statinfo"
                                   string="Farms"/>
                        </button>

                    </div>

                    <!-- ================= LOCATION DETAILS ================= -->
                    <group string="Location Details">
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <!-- ================= RELATED DETAILS ================= -->
                    <notebook>
                        <page string="Related Details">
                            <group readonly="1">
                                <field name="hdown_property_ids" widget="many2many_tags"/>
                                <field name="hdown_building_ids" widget="many2many_tags"/>
                                <field name="hdown_farm_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_estate_location_pivot" model="ir.ui.view">
        <field name="name">estate.location.pivot</field>
        <field name="model">estate.location</field>
        <field name="arch" type="xml">
            <pivot string="Location Analysis">

                <!-- ROW GROUP -->
                <field name="name" type="row"/>
                <field name="active" type="row"/>

            </pivot>
        </field>
    </record>


