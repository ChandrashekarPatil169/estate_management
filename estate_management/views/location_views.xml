    <record id="view_users_form_inherit_hierarchy" model="ir.ui.view">
        <field name="name">res.users.form.hierarchy</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <!-- Add new notebook page -->
            <xpath expr="//notebook" position="inside">

                <!-- Manager -->
                <page string="Estate Hierarchy">

                    <group>
                        <field name="parent_id"/>
                    </group>

                    <!-- Subordinates -->
                    <group string="Subordinates">
                        <field name="child_ids" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="login"/>
                            </list>
                        </field>
                    </group>

                </page>

            </xpath>

        </field>
    </record>


    <record id="view_mail_followers_edit_form_inherit_can_edit" model="ir.ui.view">
        <field name="name">mail.followers.edit.form.inherit.can.edit</field>
        <field name="model">mail.followers.edit</field>
        <field name="inherit_id" ref="mail.mail_followers_edit_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_ids']" position="after">
                <field name="can_edit"/>
            </xpath>

        </field>
    </record>
    <record id="view_partner_form_disable_image_edit" model="ir.ui.view">
        <field name="name">res.partner.form.disable.image.edit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Make image (avatar/logo) readonly -->
            <xpath expr="//field[@name='image_1920']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>
    <record id="view_users_form_disable_avatar_edit" model="ir.ui.view">
        <field name="name">res.users.form.disable.avatar</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">

            <!-- Disable avatar editing -->
            <xpath expr="//field[@name='image_1920']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>

    <record id="view_users_form_image_readonly" model="ir.ui.view">
        <field name="name">res.users.form.image.readonly</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <!-- Target the actual editable image field -->
            <xpath expr="//field[@name='image_1920']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>

    <record id="estate_hide_can_edit_field" model="ir.ui.view">
        <field name="name">mail.followers.edit.hide.can_edit</field>
        <field name="model">mail.followers.edit</field>
        <field name="inherit_id" ref="mail.mail_followers_list_edit_form"/>
        <field name="arch" type="xml">

            <!-- 🔥 HIDE FIELD COMPLETELY -->
            <xpath expr="//field[@name='can_edit']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

        </field>
    </record>





</odoo>