<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Farm list View -->
    <record id="view_farm_list" model="ir.ui.view">
        <field name="name">estate.farm.list</field>
        <field name="model">estate.farm</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="hup_property_id"/>
                <field name="hup_location_id"/>
<!--                <field name="location"/>-->
                <field name="total_area"/>
                <field name="farm_type"/>
                <field name="manager_id"/>
            </list>
        </field>
    </record>

    <!-- Farm Form View -->
    <record id="view_farm_form" model="ir.ui.view">
        <field name="name">estate.farm.form</field>
        <field name="model">estate.farm</field>
        <field name="arch" type="xml">
            <form string="Farm">
                <sheet>
                    <div class="oe_button_box" name="button_box">

                        <button name="haction_open_subfarms"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-leaf">
                            <field name="subfarm_count" widget="statinfo"/>
                        </button>

                    </div>

                    <group string="Basic Info">
                        <field name="name"/>
                        <field name="code"/>
                        <field name="hup_property_id"/>
                        <field name="hup_location_id"/>
                        <field name="total_area"/>
                        <field name="soil_type_id"/>
                        <field name="climate_zone_id"/>
                        <field name="farm_type"/>
                        <field name="manager_id"/>
                        <field name="owner_id"/>
                    </group>

                    <group string="Details">
                        <field name="ownership_type"/>
                        <field name="registration_number"/>
                        <field name="start_date"/>
                        <field name="notes"/>
                    </group>

                    <notebook>
                        <page string="Sub Farms">
                            <group>
                                <field name="subfarm_ids"
                                       widget="many2many_tags"
                                       context="{'default_farm_id':id,'default_property_id': hup_property_id,
           'default_hup_location_id':hup_location_id}"/>
                            </group>
                        </page>

                        <page string="Crops">
                            <field name="crop_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="variety"/>
                                    <field name="planting_date"/>
                                    <field name="expected_harvest_date"/>
                                </list>
                            </field>
                        </page>

                        <page string="Livestock">
                            <field name="livestock_ids">
                                <list editable="bottom">
                                    <field name="animal_type"/>
                                    <field name="breed"/>
                                    <field name="total_count"/>
                                </list>
                            </field>
                        </page>

                        <page string="Farm Tasks">
                            <field name="farm_task_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="assigned_to"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>

                        <page string="Employees">
                            <field name="employee_ids" widget="many2many_tags"/>
                        </page>

                        <page string="Assets">
                            <field name="asset_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="asset_type"/>
                                    <field name="purchase_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- FARM PIVOT VIEW -->
    <record id="view_estate_farm_pivot" model="ir.ui.view">
        <field name="name">estate.farm.pivot</field>
        <field name="model">estate.farm</field>
        <field name="arch" type="xml">

            <pivot string="Farm Analysis">

                <!-- ROW GROUPS -->
                <field name="hup_location_id" type="row"/>
                <field name="hup_property_id" type="row"/>
                <field name="farm_type" type="row"/>
                <field name="soil_type" type="row"/>
                <field name="climate_zone" type="row"/>
                <field name="manager_id" type="row"/>
                <field name="owner_id" type="row"/>

                <!-- TIME ANALYSIS -->
                <field name="start_date" interval="month" type="col"/>
                <field name="create_date" interval="month" type="col"/>

                <!-- MEASURES -->
                <field name="total_area" type="measure"/>
                <!--                <field name="id" type="measure"/>-->

            </pivot>

        </field>
    </record>

    <record id="view_sub_farm_list" model="ir.ui.view">
        <field name="name">estate.sub.farm.list</field>
        <field name="model">estate.sub.farm</field>
        <field name="arch" type="xml">
            <list>
                <field name="subfarm_id"/>
                <field name="crop_name_id"/>
                <field name="hup_location_id"/>
                <field name="property_id"/>
                <field name="crop_variety_id"/>
                <field name="planted_date"/>
                <field name="expected_harvest_date"/>
                <field name="harvested_date"/>
                <field name="harvested_quantity"/>
                <field name="cycle_type_id"/>
            </list>
        </field>
    </record>
    <record id="view_sub_farm_form" model="ir.ui.view">
        <field name="name">estate.sub.farm.form</field>
        <field name="model">estate.sub.farm</field>
        <field name="arch" type="xml">
            <form>

                <!-- SMART BUTTONS -->


                <sheet>

                    <div class="oe_button_box" name="button_box">


                        <button name="haction_open_fertilizers"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-leaf">
                            <field name="hcount_fertilizer" widget="statinfo"/>
                        </button>

                        <button name="haction_open_chemicals"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-flask">
                            <field name="hcount_chemical" widget="statinfo"/>
                        </button>

                        <button name="haction_open_workers"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users">
                            <field name="hcount_worker" widget="statinfo"/>
                        </button>
                        <button name="haction_open_harvests"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-leaf">
                            <field name="harvest_count" widget="statinfo"/>
                        </button>
                        <button name="haction_open_livestock"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-paw">
                            <field name="livestock_count" widget="statinfo" string="Livestock"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="subfarm_id"/>
                            <field name="crop_name_id"/>
                            <field name="farm_id"/>
                            <field name="hup_location_id"/>
                            <field name="property_id"/>
                            <field name="building_id" domain="[('hup_property_id', '=', property_id)]"/>

                            <field name="crop_variety_id"
                                   domain="[('id', 'in', allowed_variety_ids)]"/>
                            <field name="disease_id_main" widget="many2many_tags" domain="[('id','in',allowed_disease_ids)]"/>

                            <field name="batch_id"/>
                        </group>


                    </group>

                    <group>
                        <group string="Size Information" col="6">
                            <field name="subfarm_size" class="oe_inline"/>
                            <field name="subfarm_uom_id" class="oe_inline"/>
                        </group>


                        <group>
                            <field name="team_leader_id"/>
                            <field name="cycle_type_id"/>
                        </group>
                    </group>

                    <group>
                        <field name="irrigation_required"/>
                        <field name="well_id"
                               invisible="not irrigation_required"/>
                        <field name="motor_pump_id"
                               invisible="not irrigation_required"/>
                    </group>

                    <notebook>
                        <page string="Related Details">
                            <group>
                                <field name="fertilizer_ids" widget="many2many_tags" domain="[('id','in',allowed_fertilizer_ids)]"/>
                                <field name="chemical_ids" widget="many2many_tags" domain="[('id','in',allowed_chemical_ids)]"/>
                                <field name="worker_ids" widget="many2many_tags"/>
                                <field name="livestock_ids" widget="many2many_tags"/>

                            </group>
                        </page>
                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

