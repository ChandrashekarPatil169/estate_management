<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- list View -->
    <record id="view_estate_maintenance_request_list" model="ir.ui.view">
        <field name="name">estate.maintenance.request.list</field>
        <field name="model">estate.maintenance.request</field>
        <field name="arch" type="xml">
            <list string="Maintenance Requests" default_order="request_date desc">
                <field name="name" string="Title"/>
                <field name="property_id"/>
                <field name="unit_id"/>
                <field name="maintenance_type"/>
                <field name="status"/>
                <field name="assigned_to"/>
                <field name="schedule_date"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_estate_maintenance_request_search" model="ir.ui.view">
        <field name="name">estate.maintenance.request.search</field>
        <field name="model">estate.maintenance.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="property_id"/>
                <field name="building_id"/>
                <field name="unit_id"/>
                <field name="maintenance_type"/>
                <field name="status"/>
                <filter name="new" string="New" domain="[('status','=','new')]"/>
                <filter name="in_progress" string="In Progress" domain="[('status','=','in_progress')]"/>
                <filter name="completed" string="Completed" domain="[('status','=','completed')]"/>
            </search>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_estate_maintenance_request_form" model="ir.ui.view">
        <field name="name">estate.maintenance.request.form</field>
        <field name="model">estate.maintenance.request</field>
        <field name="arch" type="xml">
            <form string="Maintenance Request">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="maintenance_type"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="property_id"/>
                            <field name="building_id"/>
                            <field name="unit_id"/>
                            <field name="room_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Details">
                            <group>
                                <field name="description"/>
                                <field name="vendor"/>
                                <field name="assigned_to"/>
                            </group>
                        </page>
                        <page string="Cost &amp; Schedule">
                            <group>
                                <field name="cost_estimate"/>
                                <field name="actual_cost"/>
                                <field name="request_date"/>
                                <field name="schedule_date"/>
                                <field name="completion_date"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- MAINTENANCE REQUEST PIVOT -->
    <record id="view_estate_maintenance_request_pivot" model="ir.ui.view">
        <field name="name">estate.maintenance.request.pivot</field>
        <field name="model">estate.maintenance.request</field>
        <field name="arch" type="xml">
            <pivot string="Maintenance Analysis">

                <!-- ROW GROUPS -->
                <field name="property_id" type="row"/>
                <field name="building_id" type="row"/>
                <field name="unit_id" type="row"/>
                <field name="maintenance_type" type="row"/>
                <field name="status" type="row"/>
                <field name="assigned_to" type="row"/>

                <!-- TIME -->
                <field name="request_date" interval="month" type="col"/>
                <field name="completion_date" interval="month" type="col"/>

                <!-- MEASURES -->
                <field name="cost_estimate" type="measure"/>
                <field name="actual_cost" type="measure"/>
<!--                <field name="id" type="measure"/>-->

            </pivot>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estate_maintenance_request" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">estate.maintenance.request</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_estate_maintenance_root"
              name="Maintenance"
              parent="menu_estate_root"
              sequence="20"
              action="action_estate_maintenance_request"/>
</odoo>
