<!--            </pivot>-->
        </field>
    </record>

    <!-- Asset Action -->
    <record id="action_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">estate.asset</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

    <!-- Asset Menu -->
    <menuitem id="menu_asset" name="Assets" parent="menu_farm" action="action_asset" sequence="4"/>
</odoo>
