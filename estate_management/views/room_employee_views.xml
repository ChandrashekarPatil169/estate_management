    <record id="view_estate_room_employee_list" model="ir.ui.view">
        <field name="name">estate.room.employee.list</field>
        <field name="model">estate.room.employee</field>
        <field name="arch" type="xml">
            <list string="Room Employee Assignments">

                <field name="employee_id"/>
                <field name="table_id"/>
<!--                <field name="table_number"/>-->
                <field name="room_id"/>

                <field name="unit_id"/>
                <field name="floor_id"/>
                <field name="building_id"/>
                <field name="property_id"/>

                <field name="create_date"/>
                <field name="create_uid"/>

            </list>
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- 🔹 FORM VIEW -->
    <!-- ===================================================== -->
    <record id="view_estate_room_employee_form" model="ir.ui.view">
        <field name="name">estate.room.employee.form</field>
        <field name="model">estate.room.employee</field>
        <field name="arch" type="xml">
            <form string="Room Employee Assignment">

                <sheet>

                    <!-- BASIC -->
                    <group string="Assignment Details">
                        <field name="employee_id"/>
                        <field name="table_id"/>
<!--                        <field name="table_number"/>-->
                        <field name="room_id"/>
                    </group>

                    <!-- LOCATION -->
                    <group string="Location Details">
                        <field name="property_id" />
                        <field name="building_id"/>
                        <field name="floor_id"/>
                        <field name="unit_id"/>
                    </group>

                    <!-- META -->
                    <group string="Audit">
                        <field name="create_uid" readonly="1"/>
                        <field name="create_date" readonly="1"/>
                        <field name="write_uid" readonly="1"/>
                        <field name="write_date" readonly="1"/>
                    </group>


                </sheet>
                    <chatter/>


            </form>
        </field>
    </record>
    <record id="action_room_employee" model="ir.actions.act_window">
        <field name="name">Room Employees</field>
        <field name="res_model">estate.room.employee</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

    <!-- ✅ Menu Item -->
    <menuitem id="menu_room_employee"
              name="Room Employees"
              parent="menu_estate_root"
              action="action_room_employee"
              sequence="7"/>
</odoo>
