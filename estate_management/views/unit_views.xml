<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================= -->
    <!-- UNIT LIST VIEW -->
    <!-- ================================================= -->
    <record id="view_unit_list" model="ir.ui.view">
        <field name="name">estate.unit.list</field>
        <field name="model">estate.unit</field>
        <field name="arch" type="xml">
            <list string="Units">

                <!-- MAIN -->
                <field name="name"/>
                <field name="unit_number"/>
                <field name="hup_property_id"/>
                <field name="hup_building_id"/>
                <field name="occupancy_status"/>
                <field name="tenant"/>
                <field name="rent_amount"/>
                <field name="city"/>
                <field name="state"/>

                <!-- OPTIONAL -->
                <field name="pincode" optional="hide"/>
                <field name="address" optional="hide"/>

                <field name="unit_code" optional="hide"/>
                <field name="unit_type_id" optional="hide"/>
                <field name="usage_id" optional="hide"/>
                <field name="area_sqft" optional="hide"/>

                <field name="lease_start" optional="hide"/>
                <field name="lease_end" optional="hide"/>

                <field name="electricity_meter" optional="hide"/>
                <field name="water_meter" optional="hide"/>
                <field name="gas_meter" optional="hide"/>

                <field name="property_tax" optional="hide"/>
                <field name="land_tax" optional="hide"/>
                <field name="municipal_tax" optional="hide"/>

                <field name="number_of_rooms" optional="show"/>
                <field name="payment_count" optional="show"/>
                <field name="legal_document_count" optional="show"/>

            </list>

        </field>
    </record>

    <!-- ================================================= -->
    <!-- UNIT FORM VIEW -->
    <!-- ================================================= -->
    <record id="view_unit_form" model="ir.ui.view">
        <field name="name">estate.unit.form</field>
        <field name="model">estate.unit</field>
        <field name="arch" type="xml">
            <form>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_legal_documents"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-paperclip">
                            <field name="legal_document_count"
                                   widget="statinfo"
                                   string="Documents"/>
                        </button>

                        <button name="haction_open_rooms"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-th-large"
                        >
                            <field name="hcount_room" widget="statinfo"/>
                        </button>

                        <button name="haction_open_tables"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-table"
                        >
                            <field name="hcount_table" widget="statinfo"/>
                        </button>
                        <button name="action_open_payments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Payments"/>
                        </button>
                    </div>


                    <!-- ================= BASIC DETAILS ================= -->
                    <group string="Unit Details">
                        <group>
                            <field name="name"/>
                            <!--                            <field name="floor_id"/>-->
                            <field name="unit_code"/>
                            <field name="unit_type_id"/>
                            <field name="area_sqft"/>
                            <field name="usage_id"/>
                            <!--                            <field name="internet_service"/>-->
                        </group>

                        <group>
                            <field name="occupancy_status"/>
                            <field name="tenant"/>
                            <field name="water_tank"/>


                        </group>
                    </group>
                    <group string="Address Details">

                        <!-- Full width address (better UX) -->
                        <group>
                            <field name="address"/>
                        </group>

                        <!-- Location details -->
                        <group>
                            <field name="city"/>
                            <field name="state"/>
                            <field name="pincode" placeholder="Enter 6-digit pincode"/>
                        </group>

                        <!-- Additional info -->
                        <group>
                            <field name="unit_number"/>
                            <field name="responsible_employee_id"/>
                        </group>

                    </group>
                    <!-- ================= LEASE DETAILS ================= -->
                    <group string="Lease Information">
                        <group>
                            <field name="lease_start"/>
                            <field name="lease_end"/>
                        </group>
                        <group>
                            <field name="rent_amount"/>
                        </group>
                    </group>

                    <!-- ================= UTILITIES ================= -->
                    <group string="Utilities">

                        <group>
                            <field name="internet_bill"/>
                            <field name="maintenance_charges"/>
                        </group>
                    </group>


                    <!-- ================= TAXES ================= -->
                    <group string="Taxes">
                        <group>
                            <field name="property_tax"/>
                            <field name="land_tax"/>
                            <field name="municipal_tax"/>
                            <!--                            <field name="unit_property_tax"/>-->
                        </group>
                        <group>

                            <field name="water_tax"/>
                            <field name="electricity_meter"/>
                            <field name="water_meter"/>
                            <field name="gas_meter"/>
                        </group>
                        <group>

                        </group>
                    </group>

                    <!-- ================= STATISTICS ================= -->
                    <group string="Statistics" invisible="1">
                        <group>
                            <field name="number_of_rooms" readonly="1"/>
                        </group>
                        <group>
                            <field name="employee_count" readonly="1"/>
                        </group>
                    </group>

                    <group string="Unit Documents">
                        <field name="legal_document_ids" widget="many2many_binary"/>
                    </group>

                    <!-- ================= NOTEBOOK ================= -->
                    <notebook>

                        <!-- ROOMS -->
                        <page string="Rooms" invisible="1">
                            <field name="room_ids" editable="bottom">
                                <list>
                                    <field name="name"/>
                                    <field name="room_type"/>
                                </list>
                            </field>
                        </page>

                        <!-- PAYMENTS -->
                        <page string="Payments">
                            <field name="payment_ids" editable="bottom" context="{
           'default_property_id': hup_property_id,
           'default_building_id': hup_building_id
       }">
                                <list>
                                    <field name="product_id"/>
                                    <field name="meter_start_reading"/>
                                    <field name="meter_end_reading"/>
                                    <field name="meter_consumed" readonly="1"/>
                                    <field name="amount"/>
                                    <field name="due_date"/>
                                </list>
                            </field>
                        </page>

                    </notebook>

                </sheet>

                <!-- ================= CHATTER (RIGHT SIDE) ================= -->
                <chatter/>

            </form>
        </field>
    </record>

    <!-- UNIT PIVOT -->
    <record id="view_unit_pivot" model="ir.ui.view">
        <field name="name">estate.unit.pivot</field>
        <field name="model">estate.unit</field>
        <field name="arch" type="xml">

            <pivot string="Unit Analysis">

                <!-- ROW GROUPS -->
                <field name="hup_location_id" type="row"/>
                <field name="hup_property_id" type="row"/>
                <field name="hup_building_id" type="row"/>
                <field name="hup_floor_id" type="row"/>
                <field name="unit_type_id" type="row"/>

                <!-- COLUMN -->
                <field name="occupancy_status" type="col"/>

                <!-- TIME -->
                <field name="create_date" interval="month" type="col"/>

                <!-- MEASURES -->
                <field name="area_sqft" type="measure"/>
                <field name="rent_amount" type="measure"/>
                <field name="number_of_rooms" type="measure"/>
                <field name="employee_count" type="measure"/>
                <!--                <field name="id" type="measure"/>-->

            </pivot>

        </field>
    </record>

    <record id="view_estate_unit_form_hierarchy_full" model="ir.ui.view">
        <field name="name">estate.unit.form.hierarchy.full</field>
        <field name="model">estate.unit</field>
        <field name="inherit_id" ref="estate_management.view_unit_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/group" position="inside">
                <group string="Details">
                    <field name="hup_floor_id"/>
                    <field name="hup_building_id"/>
                    <field name="hup_property_id"/>
                    <field name="hup_location_id"/>

                </group>
            </xpath>

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Related Details">
                    <group readonly="1">
                        <field name="hdown_room_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>


</odoo>


