<?xml version="1.0" encoding="utf-8"?><odoo>    <data>        <!-- Joining Date Label Change -->        <record id="view_employee_form_inherit_joining_date" model="ir.ui.view">            <field name="name">hr.employee.form.inherit.joining.date</field>            <field name="model">hr.employee</field>            <field name="inherit_id" ref="hr.view_employee_form"/>            <field name="arch" type="xml">                <xpath expr="//page[@name='payroll_information']//label[@for='contract_date_start']"                       position="replace">                    <label for="contract_date_start" string="Joining Date"/>                </xpath>            </field>        </record>        <!-- Aadhar Label Change -->        <record id="view_employee_form_inherit_aadhar_label" model="ir.ui.view">            <field name="name">hr.employee.form.inherit.aadhar.label</field>            <field name="model">hr.employee</field>            <field name="inherit_id" ref="hr.view_employee_form"/>            <field name="arch" type="xml">                <xpath expr="//field[@name='identification_id']" position="attributes">                    <attribute name="string">Aadhar Number</attribute>                </xpath>            </field>        </record>        <!-- Reporting Manager Label Change -->        <record id="view_employee_form_inherit_manager_label" model="ir.ui.view">            <field name="name">hr.employee.form.inherit.manager.label</field>            <field name="model">hr.employee</field>            <field name="inherit_id" ref="hr.view_employee_form"/>            <field name="arch" type="xml">                <xpath expr="//field[@name='parent_id']" position="attributes">                    <attribute name="string">Reporting Manager</attribute>                </xpath>            </field>        </record>        <!-- Add Employee ID Below Job Title -->        <record id="view_employee_form_inherit_employee_id_header"                model="ir.ui.view">            <field name="name">hr.employee.form.employee.id.header</field>            <field name="model">hr.employee</field>            <field name="inherit_id" ref="hr.view_employee_form"/>            <field name="arch" type="xml">                <xpath expr="//field[@name='job_title']" position="after">                    <field name="employee_id" placeholder="Employee ID"/>                </xpath>            </field>        </record>    </data></odoo>