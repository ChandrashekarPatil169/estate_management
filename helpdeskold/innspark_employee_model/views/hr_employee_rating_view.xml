<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_form_inherit_rating" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.rating</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <page string="Ratings" name="employee_ratings">
                    <field name="rating_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="rating"/>
                            <field name="comments"/>
                        </list>
                    </field>
                </page>

            </xpath>

        </field>
    </record>

</odoo>
