<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_employee_report_list" model="ir.ui.view">
        <field name="name">employee.report.list</field>
        <field name="model">employee.report</field>
        <field name="arch" type="xml">
            <list>
                <!--                <field name="name"/>-->
                <field name="employee_id"/>
                <field name="date"/>
                <field name="rating" widget="priority"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_employee_report_form" model="ir.ui.view">
        <field name="name">employee.report.form</field>
        <field name="model">employee.report</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date"/>
                        <field name="rating" widget="priority" />

                        <field name="comments"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

