<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_form_inherit_education" model="ir.ui.view">
        <field name="name">hr.employee.form.education</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- Add Educational Background as a notebook page -->
            <xpath expr="//notebook" position="inside">
                <page string="Educational Background" name="educational_background">
                    <field name="education_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="education_level"/>
                            <field name="institute_name"/>
                            <field name="field_of_study"/>
                            <field name="issuing_authority"/>
                            <field name="year_of_passing"/>
                            <field name="certificate_file"
                                   filename="certificate_filename"/>
                            <field name="certificate_filename" invisible="1"/>
                        </list>
                    </field>
                </page>
                 <page string="Challenges" name="employee_challenges">

                    <field name="challenge_line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="challenge_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="state"/>
                        </list>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
