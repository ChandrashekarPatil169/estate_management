<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_employee_form_inherit_work_tax_benefits" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.work.tax.benefits</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- Insert AFTER Usual Work Location -->
            <xpath expr="//group[@name='departure']/following-sibling::group[1]"
                   position="after">

                <group string="Tax Information">
                    <field name="pan_number"/>
                    <field name="tax_deduction"/>
                </group>

                <group string="Benefits">
                    <field name="health_insurance"/>
                    <field name="provident_fund"/>
                    <field name="gratuity"/>
                </group>

            </xpath>

        </field>
    </record>

</odoo>
