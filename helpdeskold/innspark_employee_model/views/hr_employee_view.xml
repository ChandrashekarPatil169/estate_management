<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Personal fields -->
        <record id="hr_employee_form_inherit_personal_fields" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.personal.fields</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='legal_name']" position="after">
                    <field name="first_name"/>
                    <field name="middle_name"/>
                    <field name="last_name"/>
                    <field name="full_name" readonly="1"/>
                    <field name="blood_group"/>
                </xpath>

                <xpath expr="//group[@name='hr_birth_group']/div[@name='div_km_home_work']" position="after">
                    <field name="age" readonly="1"/>
                </xpath>
            </field>
        </record>

        <!-- Alternative Email -->
        <record id="hr_employee_form_inherit_alternative_email" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.alternative.email</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='private_email']" position="after">
                    <field name="alternative_email"/>
                </xpath>
            </field>
        </record>

        <!-- Mentor -->
        <record id="hr_employee_form_inherit_mentor" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.mentor</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='parent_id']" position="after">
                    <field name="mentor_id" widget="many2one_avatar_employee"/>
                    <field name="rfid"/>
                    <field name="date_of_joining"/>
                </xpath>
            </field>
        </record>

        <!-- Emergency -->
        <record id="hr_employee_form_inherit_emergency_contact_extra" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.emergency.contact.extra</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='emergency_contact']" position="after">
                    <field name="emergency_contact_name"/>
                    <field name="emergency_contact_relation"/>
                    <field name="emergency_contact_email"/>
                    <field name="emergency_contact_address"/>
                </xpath>
            </field>
        </record>

        <!-- Alternative Address -->
        <record id="hr_employee_form_inherit_alt_address" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.alt.address</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='hr_location_group']/div[@name='div_km_home_work']" position="after">
                    <div class="o_form_label">Alternative Address</div>
                    <div class="o_address_format">
                        <field name="same_as_private_address"/>
                        <field name="alternative_street"/>
                        <field name="alternative_street2"/>
                        <field name="alternative_city"/>
                        <field name="alternative_state_id"/>
                        <field name="alternative_zip"/>
                        <field name="alternative_country_id"/>
                    </div>
                </xpath>
            </field>
        </record>

        <!-- Experience -->
        <record id="view_employee_form_experience" model="ir.ui.view">
            <field name="name">hr.employee.form.experience</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_of_joining']" position="after">
                    <field name="experience" readonly="1"/>
                </xpath>
            </field>
        </record>

        <!-- Tab reorder -->
        <record id="hr_employee_form_reorder_tabs" model="ir.ui.view">
            <field name="name">hr.employee.form.reorder.tabs</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="priority">1200</field>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='work_information']" position="before">
                    <xpath expr="//page[@name='personal_information']" position="move"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>


