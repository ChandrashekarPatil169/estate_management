<odoo>
    <record id="view_auth_attempt_list" model="ir.ui.view">
        <field name="name">auth.attempt.list</field>
        <field name="model">res.authentication.attempt</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="remote_ip"/>
                <field name="login"/>
                <field name="result"/>
            </list>
        </field>
    </record>

    <record id="view_auth_attempt_form" model="ir.ui.view">
        <field name="name">auth.attempt.form</field>
        <field name="model">res.authentication.attempt</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="create_date"/>
                        <field name="remote_ip"/>
                        <field name="login"/>
                        <field name="result"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_auth_attempts" model="ir.actions.act_window">
        <field name="name">Authentication Attempts</field>
        <field name="res_model">res.authentication.attempt</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
