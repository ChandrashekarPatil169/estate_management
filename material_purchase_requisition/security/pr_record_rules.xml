<odoo>
    <record id="rule_pr_visibility_user" model="ir.rule">
    <field name="name">PR visibility</field>
    <field name="model_id" ref="model_material_purchase_requisition"/>
    <field name="groups" eval="[(4, ref('base.group_user'))]"/>

    <field name="domain_force">
        ['|','|','|',
        ('employee_id.user_id', '=', user.id),
        ('current_approver_id', '=', user.id),
        ('approval_log_ids.user_id', '=', user.id),
        ('employee_id.visible_to_user_ids', 'in', [user.id])
        ]
    </field>
</record>

    <!-- Admin rule -->
    <record id="rule_pr_visibility_admin" model="ir.rule">
        <field name="name">PR visibility: admin sees all</field>
        <field name="model_id" ref="model_material_purchase_requisition"/>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>


</odoo>
