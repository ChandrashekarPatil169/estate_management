<odoo>

    <record id="mail_template_rfq_sent" model="mail.template">
        <field name="name">RFQ Sent Notification</field>

        <!-- IMPORTANT: PR MODEL -->
        <field name="model_id" ref="model_material_purchase_requisition"/>

        <field name="subject">
            <![CDATA[RFQ Sent to Vendor]]>
        </field>
        <field name="auto_delete">False</field>
        <field name="email_from">{{ object.company_id.email }}</field>



        <!-- MUST BE EMPTY -->
        <field name="email_to"></field>

        <field name="auto_delete">False</field>

        <field name="body_html">
            <![CDATA[
            <t t-set="po" t-value="env['purchase.order'].browse(ctx.get('current_po_id'))"/>

            <p>
                📧 RFQ has been sent for Purchase Requisition
                <b><t t-out="object.name"/></b>
            </p>

            <p>
                <b>Vendor:</b>
                <t t-out="po.partner_id.name"/>
            </p>

            <p>
                <b>RFQ Reference:</b>
                <t t-out="po.name"/>
            </p>

            <p><b>Products:</b></p>

            <ul>
                <t t-foreach="po.order_line" t-as="line">
                    <li>
                        <t t-out="line.product_id.display_name"/>
                        -
                        Qty: <t t-out="line.product_qty"/>
                    </li>
                </t>
            </ul>
            ]]>
        </field>

    </record>

</odoo>