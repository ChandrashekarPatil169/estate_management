<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_pr_reject_wizard_form" model="ir.ui.view">
        <field name="name">pr.reject.wizard.form</field>
        <field name="model">pr.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Purchase Requisition">
                <group>
                    <field name="rejection_reason"
                           placeholder="Explain clearly why this PR is rejected"
                           required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
