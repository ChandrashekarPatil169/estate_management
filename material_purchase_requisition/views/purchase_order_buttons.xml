<odoo>

    <record id="purchase_order_form_extend_buttons_received" model="ir.ui.view">
        <field name="name">purchase.order.form.extend.buttons.received</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- BILL BUTTON -->
            <xpath expr="//button[contains(@name,'invoice')]" position="attributes">
                <attribute name="invisible">
                    state not in ('purchase','done')
                </attribute>
            </xpath>



        </field>
    </record>

</odoo>
