<odoo>
    <record id="view_pr_rfq_wizard_form" model="ir.ui.view">
        <field name="name">material.pr.rfq.wizard.form</field>
        <field name="model">material.pr.rfq.wizard</field>
        <field name="arch" type="xml">
            <form string="Create RFQs">
                <group>
                    <field name="pr_id"/>
                    <field name="vendor_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button
                            string="Create RFQs"
                            type="object"
                            name="action_confirm_create_rfqs"
                            class="btn-primary"
                    />
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
