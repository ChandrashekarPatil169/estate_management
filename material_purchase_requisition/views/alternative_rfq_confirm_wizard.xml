<odoo>
    <record id="view_alternative_rfq_confirm_wizard_form" model="ir.ui.view">
        <field name="name">material.alternative.rfq.confirm.wizard.form</field>
        <field name="model">material.alternative.rfq.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm RFQ">
                <group>
                    <field name="po_id"/>
                    <field name="alternative_rfq_ids" widget="many2many_tags"/>
                    <field name="decision"/>
                </group>
                <footer>
                    <button
                            name="action_confirm"
                            type="object"
                            string="Confirm"
                            class="btn-primary"
                    />
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
