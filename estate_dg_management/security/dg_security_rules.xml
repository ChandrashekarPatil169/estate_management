<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="dg_rule" model="ir.rule">
        <field name="name">DG Access</field>
        <field name="model_id" ref="model_estate_dg"/>
        <field name="domain_force">
            ['|','|',
            ('create_uid', '=', user.id),
            ('message_partner_ids', 'in', [user.partner_id.id]),
            '&amp;',
            ('create_uid', '!=', 1),
            ('create_uid', 'child_of', user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('estate_dg_management.group_dg_user')),
                                   (4, ref('estate_dg_management.group_dg_employee')),
                                   (4, ref('estate_dg_management.group_dg_manager')),
                                   (4, ref('estate_dg_management.group_dg_general_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="True"/>
    </record>

