<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- CATEGORY -->
    <record id="dg_hierarchy_category" model="ir.module.category">
        <field name="name">DG Management</field>
        <field name="sequence">30</field>
    </record>

    <!-- PRIVILEGE -->
    <record id="privilege_dg_management" model="res.groups.privilege">
        <field name="name">DG Hierarchy</field>
        <field name="category_id" ref="estate_dg_management.dg_hierarchy_category"/>
    </record>

    <!-- GROUPS -->

    <record id="group_dg_user" model="res.groups">
        <field name="name">DG User</field>
        <field name="privilege_id" ref="estate_dg_management.privilege_dg_management"/>
    </record>

    <record id="group_dg_employee" model="res.groups">
        <field name="name">DG Employee</field>
        <field name="privilege_id" ref="estate_dg_management.privilege_dg_management"/>
        <field name="implied_ids" eval="[(4, ref('estate_dg_management.group_dg_user'))]"/>
    </record>

    <record id="group_dg_manager" model="res.groups">
        <field name="name">DG Manager</field>
        <field name="privilege_id" ref="estate_dg_management.privilege_dg_management"/>
        <field name="implied_ids" eval="[(4, ref('estate_dg_management.group_dg_employee'))]"/>
    </record>

    <record id="group_dg_general_manager" model="res.groups">
        <field name="name">DG General Manager</field>
        <field name="privilege_id" ref="estate_dg_management.privilege_dg_management"/>
        <field name="implied_ids" eval="[(4, ref('estate_dg_management.group_dg_manager'))]"/>
    </record>

</odoo>




