    <record id="subtask_hierarchy_rule" model="ir.rule">
        <field name="name">Subtask: Assigned Access</field>
        <field name="model_id" ref="model_project_subtask"/>
        <field name="domain_force">
            [
            '|', '|', '|', '|', '|',
            ('project_id.program_manager_id', '=', user.id),
            ('project_id.user_id', '=', user.id),
            ('assignee_id', '=', user.id),
            ('create_uid', '=', user.id),
            ('message_partner_ids', 'in', [user.partner_id.id]),
            ('allow_timesheet_user_ids', 'in', [user.id])
            ]
        </field>
        <field name="groups" eval="[
        (4, ref('project_main_mgmt.group_program_manager')),
        (4, ref('project_main_mgmt.group_custom_project_manager')),
        (4, ref('project.group_project_user'))
    ]"/>
    </record>


