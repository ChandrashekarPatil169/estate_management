    <record id="task_assignee_follower_rule" model="ir.rule">
        <field name="name">Task access for assignee/follower</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">
            ['|',
            ('user_ids', 'in', [user.id]),
            ('message_partner_ids', 'in', [user.partner_id.id])
            ]
        </field>
        <field name="perm_read" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>
    <record id="timesheet_rule_internal" model="ir.rule">
        <field name="name">Timesheet access for assignee</field>
        <field name="model_id" ref="analytic.model_account_analytic_line"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">
            ['|',
            ('task_id.user_ids', 'in', [user.id]),
            ('task_id.message_partner_ids', 'in', [user.partner_id.id])
            ]
        </field>
        <field name="perm_read" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="task_timesheet_user_rule" model="ir.rule">
