<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================= -->
    <!-- View: Add Program Manager in Project Form -->
    <!-- ========================= -->

    <record id="view_project_form_add_program_manager" model="ir.ui.view">
        <field name="name">project.project.form.add.program.manager</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="program_manager_id"
                       string="Program Manager"
                       widget="many2one_avatar_user"
                       domain="[('share', '=', False)]"
                       groups="project.group_project_user"/>
            </xpath>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Disable Default Conflicting Rules -->
    <!-- ========================= -->

    <record id="project.project_project_manager_rule" model="ir.rule">
        <field name="active">0</field>
    </record>

    <!--        <record id="project.project_public_members_rule" model="ir.rule">-->
    <!--            <field name="active">0</field>-->
    <!--        </record>-->

    <!--        <record id="project.task_visibility_rule" model="ir.rule">-->
    <!--            <field name="active">0</field>-->
    <!--        </record>-->

    <!--        <record id="project.task_visibility_rule_project_user" model="ir.rule">-->
    <!--            <field name="active">0</field>-->
    <!--        </record>-->

    <record id="project.project_manager_all_project_tasks_rule" model="ir.rule">
        <field name="active">0</field>
    </record>

    <!-- ========================= -->
    <!-- Custom Groups -->
    <!-- ========================= -->

    <record id="group_program_manager" model="res.groups">
        <field name="name">Program Manager</field>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>

    <record id="group_custom_project_manager" model="res.groups">
        <field name="name">Project Manager</field>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>
    <record id="group_timesheet_user_custom" model="res.groups">
        <field name="name">Timesheet User</field>
    </record>
    <!-- ========================= -->
    <!-- PROJECT ACCESS -->
    <!-- ONLY custom groups, NOT project.group_project_user -->
    <!-- ========================= -->
    <record id="project_project_hierarchy_rule" model="ir.rule">
        <field name="name">Project: Manager / Creator Access</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">
            [
            '|', '|',
            ('program_manager_id', '=', user.id),
            ('user_id', '=', user.id),
            ('create_uid', '=', user.id)
            ]
        </field>

        <field name="groups" eval="[
            (4, ref('project_main_mgmt.group_program_manager')),
            (4, ref('project_main_mgmt.group_custom_project_manager'))
        ]"/>
    </record>

