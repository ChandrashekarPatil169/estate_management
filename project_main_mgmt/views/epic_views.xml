    <record id="view_project_epic_timeline" model="ir.ui.view">
        <field name="name">project.epic.timeline</field>
        <field name="model">project.epic</field>
        <field name="type">timeline</field>
        <field name="arch" type="xml">
            <timeline
                    string="Epic Timeline"
                    date_start="planned_start_date"
                    date_stop="planned_end_date"
                    default_group_by="owner_id"
                    event_open_popup="true"
                    colors="#2ecb71: epic_status == 'done';
#ec7063: epic_status == 'cancelled';
#f4d03f: epic_status == 'at_risk';
#5dade2: epic_status == 'on_track'"
            >

                <!-- Load fields -->
                <field name="name"/>
                <field name="project_id"/>
                <field name="backlog_id"/>
                <field name="epic_status"/>
                <field name="priority"/>
                <field name="owner_id"/>
                <field name="planned_start_date"/>
                <field name="planned_end_date"/>
                <field name="expected_end_date"/>
                <field name="completed_date"/>
                <field name="epic_progress"/>

                <templates>
                    <t t-name="timeline-item">
                        <div style="white-space: nowrap; font-size: 13px;">

                            <!-- Epic Name -->

                            <t t-out="record.name"/>

                            <!-- Planned Dates -->
                            <t t-if="record.planned_start_date and record.planned_end_date">
                                | Planned:
                                <t t-out="record.planned_start_date"/>
                                -
                                <t t-out="record.planned_end_date"/>
                            </t>

                            <!-- Expected -->
                            <t t-if="record.expected_end_date">
                                |
                                <span style="color:#dc3545;">
                                    Exp:
                                    <t t-out="record.expected_end_date"/>
                                </span>
                            </t>

                            <!-- Completed -->
                            <t t-if="record.completed_date">
                                |
                                <span style="color:#2ecb71;">
                                    Done:
                                    <t t-out="record.completed_date"/>
                                </span>
                            </t>
                            <t t-set="progress" t-value="record.epic_progress || 0"/>

                            <t t-set="bar_color"
                               t-value="progress &lt; 30
                                        ? '#dc3545'
                                        : (progress &lt; 70
                                        ? '#f4d03f'
                                        : '#2ecb71')"/>

                            <div style="margin-top:5px; width:200px;">
                                <div style="background:#e9ecef; height:6px; border-radius:4px;">
                                    <div t-att-style="'width:' + progress + '%; height:6px; border-radius:4px; background:' + bar_color + ';'">
                                    </div>
                                </div>
                                <small style="font-size:11px;">
                                    <t t-esc="progress.toFixed(1)"/>%
                                </small>
                            </div>

                        </div>
                    </t>
                </templates>

            </timeline>
        </field>
    </record>

