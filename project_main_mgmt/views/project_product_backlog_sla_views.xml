<odoo>
    <record id="view_product_backlog_sla_kanban" model="ir.ui.view">
        <field name="name">product.backlog.sla.kanban</field>
        <field name="model">product.backlog</field>
        <!-- 🔥 IMPORTANT -->
        <field name="priority">100</field>
        <field name="arch" type="xml">


            <kanban default_group_by="sla_stage"
                    class="o_kanban_small_column">

                <!-- 🔥 LOAD ALL REQUIRED FIELDS -->
                <field name="name"/>
                <field name="sla_stage"/>
                <field name="project_id"/>
                <field name="subproject_id"/>
                <field name="planned_start_date"/>
                <field name="planned_end_date"/>
                <field name="expected_end_date"/>

                 <field name="estimate"/>
                <field name="backlog_progress"/>
                <field name="progress_color"/>



                <field name="assignee_id"/>




                <templates>

                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_record p-3">

                            <!-- 🔵 PROJECT -->
                            <div class="text-primary fw-bold">
                                <field name="project_id"/>
                            </div>


                             <!-- 🟣 SUBPROJECT + BACKLOG -->
                            <div class="fw-bold text-primary fs-5 mb-1">

                                <!-- if subproject exists -->
                                <t t-if="record.subproject_id.raw_value">
                                    <field name="subproject_id"/>
                                    →
                                </t>

                                <!-- backlog -->
                                <field name="name"/>

                            </div>
                            <!-- ASSIGNEE -->
                            <div class="text-muted small">
                                <field name="assignee_id"
                                       widget="many2one_avatar_user"/>
                            </div>


                            <!-- START DATE -->
                            <div class="text-muted small mt-1">
                                Start:
                                <field name="planned_start_date"/>
                            </div>

                            <!-- END DATE -->
                            <div class="text-muted small">
                                End:
                                <field name="planned_end_date"/>
                            </div>

                            <!-- EXPECTED DATE -->
                            <div class="text-muted small">
                                Expected:
                                <field name="expected_end_date"/>
                            </div>

                            <!-- ESTIMATE -->
                            <div class="fw-bold text-info small mt-1">
                                Estimate:
                                <field name="estimate"/>
                                hrs
                            </div>


                            <!-- PROGRESS BAR -->
                            <div class="progress mt-2" style="height:8px;">
                                <div t-att-class="'progress-bar ' + (record.progress_color.raw_value or 'bg-primary')"
                                     role="progressbar"
                                     t-att-style="'width:' + (record.backlog_progress.raw_value or 0) + '%;'">
                                </div>
                            </div>

                            <div class="small text-muted mt-1">
                                <t t-esc="record.backlog_progress.raw_value or 0"/>%
                            </div>

                            <!-- 🔥 SLA BADGE -->
                            <div class="mt-2">

                                <span t-if="record.sla_stage.raw_value == 'green'"
                                      class="badge rounded-pill bg-success">
                                    Green
                                </span>

                                <span t-if="record.sla_stage.raw_value == 'amber'"
                                      class="badge rounded-pill bg-warning text-dark">
                                    Amber
                                </span>

                                <span t-if="record.sla_stage.raw_value == 'red'"
                                      class="badge rounded-pill bg-danger">
                                    Red
                                </span>

                                <span t-if="record.sla_stage.raw_value == 'red_3'"
                                      class="badge rounded-pill bg-danger">
                                    Overdue +3
                                </span>

                                <span t-if="record.sla_stage.raw_value == 'red_6'"
                                      class="badge rounded-pill bg-danger">
                                    Overdue +6
                                </span>


                            </div>

                        </div>
                    </t>

                </templates>

            </kanban>

        </field>
    </record>
</odoo>