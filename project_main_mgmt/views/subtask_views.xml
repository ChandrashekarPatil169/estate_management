    <record id="view_subtask_kanban" model="ir.ui.view">
        <field name="name">project.subtask.kanban</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">

            <kanban default_group_by="stage_id" domain="[('parent_id','=',False)]">

                <!-- fields -->
                <field name="project_id"/>
                <field name="name"/>
                <field name="task_id"/>
                <field name="expected_end_date"/>
                <field name="planned_start_date"/>
                <field name="planned_end_date"/>
                <field name="estimate"/>
                <field name="subtask_progress"/>
                <field name="task_type_id"/>
                <field name="progress_color" invisible="1"/>

                <templates>
                    <t t-name="card">

                        <div class="oe_kanban_card p-3 rounded shadow-sm">
                            <!-- 🔥 PROJECT -->
                            <div class="text-muted small fw-bold text-info">
                                <field name="project_id"/>
                            </div>

                            <!-- 🔥 TASK + SUBTASK TITLE -->
                            <div class="fw-bold fs-5 mb-2 text-primary">
                                <field name="task_id"/>
                                →
                                <field name="name"/>
                            </div>

                            <!-- dates -->
                            <div class="text-muted small">
                                <b>Start:</b>
                                <field name="planned_start_date"/>
                            </div>

                            <div class="text-muted small">
                                <b>End:</b>
                                <field name="planned_end_date"/>
                            </div>

                            <div class="text-muted small">
                                <b>Expected:</b>
                                <field name="expected_end_date"/>
                            </div>

                            <!-- estimate -->
                            <div class="text-muted small mt-1">
                                <b>Estimate:</b>
                                <field name="estimate"/>
                                hrs
                            </div>
                            <div class="fw-bold text-info small">
                                Sub Task Type:
                                <field name="task_type_id"/>

                            </div>

                            <!-- 🔥 progress -->
                            <div class="progress mt-2" style="height:8px;">
                                <div t-att-class="'progress-bar ' + (record.progress_color.raw_value or 'bg-primary')"
                                     role="progressbar"
                                     t-att-style="'width:' + (record.subtask_progress.raw_value or 0) + '%;'"></div>
                            </div>

                            <div class="small text-muted mt-1">
                                <t t-esc="record.subtask_progress.raw_value or 0"/>
                                %
                            </div>
                            <div class="o_kanban_footer d-flex justify-content-end">
                                <div class="kanban_status_big">
                                    <field name="status"
                                           widget="state_selection"
                                           options="{'clickable': True}"/>
                                </div>
                            </div>

                            <!-- stage -->
                            <!-- <div class="mt-2">-->
                            <!-- <span class="badge bg-secondary">-->
                            <!-- <field name="stage_id"/>-->
                            <!-- </span>-->
                            <!-- </div>-->

                        </div>

                    </t>
                </templates>

            </kanban>

        </field>
