<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================= -->
    <!-- LIST VIEW -->
    <!-- ================================= -->
    <record id="view_project_subtask_list" model="ir.ui.view">
        <field name="name">project.subtask.list</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="story_id"/>
                <field name="assignee_id"/>
                <field name="estimate"/>
                <field name="status"/>
                <field name="subtask_progress" widget="progressbar"/>

            </list>
        </field>
    </record>

    <!-- ================================= -->
    <!-- FORM VIEW (Your Existing) -->
    <!-- ================================= -->
    <record id="view_project_subtask_form" model="ir.ui.view">
        <field name="name">project.subtask.form</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <form string="Subtask">
                <!-- ✅ HEADER MUST BE HERE -->
                <header>
                    <field name="stage_id"
                           widget="statusbar"
                           class="my-custom-stages"
                           options="{'clickable': 1, 'fold_field': 'fold'}"/>
                </header>
                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <!-- NEW: Documents Smart Button -->
                        <button name="action_view_documents" type="object" class="oe_stat_button" icon="fa-paperclip">
                            <field name="document_count" string="Documents" widget="statinfo"/>
                        </button>

                        <button name="action_view_child_subtasks"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-sitemap">

                            <field name="subtask_count"
                                   string="Subtasks"
                                   widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="task_id"/>
                        <field name="story_id"/>
                        <field name="task_type_id"/>
                        <field name="task_label_id"/>
                        <field name="assignee_id"/>
                        <field name="priorities"/>
                        <field name="estimate"/>
                        <field name="status"/>
                        <field name="tag_ids"
                               widget="many2many_tags"
                               domain="[('project_ids', '=', project_id)]"
                               options="{'color_field': 'color', 'no_create_edit': True}"
                               context="{'project_id': project_id}"/>
                        <field name="subtask_weightage"/>
                        <field name="planned_start_date"/>
                        <field name="planned_end_date"/>
                        <field name="expected_end_date"/>
                        <field name="completed_date" readonly="1"/>
                        <field name="subtask_progress" widget="progressbar"/>

                    </group>

                    <!-- NOTEBOOK -->
                    <notebook>

                        <!-- GOVERNANCE PAGE -->
                        <page string="Governance">

                            <group>
                                <!-- Select who can approve -->
                                <field name="approver_ids"
                                       widget="many2many_tags"
                                       options="{'no_create': True}"/>

                                <field name="evidence_required"
                                       options="{'resizable': false}"
                                       placeholder="Add evidence here..."/>

                                <!-- Audit info -->
                                <field name="approved_by_id" readonly="1"/>

                                <!-- Internal flag -->
                                <field name="is_done" invisible="1"/>


                            </group>

                            <group>
                                <button name="action_mark_done"
                                        type="object"
                                        string="Approve &amp; Mark Done"
                                        class="glow-on-hover"
                                        invisible="is_done"/>

                                <!-- In the Subtask form view -->
                                <!--                                <button name="action_mark_done"-->
                                <!--                                        type="object"-->
                                <!--                                        string="Mark Done"-->
                                <!--                                        invisible="project_id_state != 'approved' or is_done == True"-->
                                <!--                                        class="oe_highlight"/>-->

                            </group>

                        </page>
                        <!-- NEW: Documents Page -->
                        <page string="Documents" name="documents_page">
                            <field name="document_ids" widget="many2many_binary" string="Attach Files"/>
                        </page>
                        <page string="Notes">
                            <field name="inherited_notes" readonly="1" widget="html"/>
                        </page>
                        <page string="Subtasks">

                            <field name="child_ids"
                                   context="{
                                    'default_parent_id': id,
                                    'default_task_id': task_id,
                                    'default_project_id': project_id
                                    }"
                                   mode="list,form"
                                   options="{'no_open': False}">

                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="assignee_id"/>
                                    <field name="stage_id"/>
                                    <field name="estimate"/>
                                    <field name="subtask_progress" widget="progressbar"/>
                                </list>

                            </field>

                        </page>
                        <page name="sla" string="SLA">


                            <!-- SLA Overview -->
                            <group class="row mt16 o_settings_container">
                                <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                    SLA Overview
                                </div>


                                <setting class="col-lg-12">
                                    <field name="sla_risk"
                                           widget="badge"
                                           decoration-success="sla_risk == 'green'"
                                           decoration-warning="sla_risk == 'amber'"
                                           decoration-danger="sla_risk == 'red'"/>


                                    <field name="sla_days_label" widget="badge"/>
                                </setting>
                            </group>
                            <!-- SLA Monitoring -->
                            <group class="row mt16 o_settings_container">
                                <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                    SLA Monitoring
                                </div>


                                <setting class="col-lg-12">
                                    <button name="action_open_child_subtask_sla_monitoring"
                                            type="object"
                                            class="btn btn-link p-0"
                                            icon="fa-shield">
                                        Open Child Subtask SLA Monitoring
                                    </button>
                                </setting>
                            </group>


                            <!-- SLA Deadlines -->
                            <group class="row mt16 o_settings_container">


                                <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                    SLA Deadlines
                                </div>


                                <setting class="col-lg-6">
                                    <button name="action_open_child_subtask_sla_7_days"
                                            type="object"
                                            class="btn btn-outline-primary w-100"
                                            icon="fa-calendar">
                                        Upcoming (Next 7 Days)
                                    </button>
                                </setting>


                                <setting class="col-lg-6">
                                    <button name="action_open_child_subtask_sla_30_days"
                                            type="object"
                                            class="btn btn-outline-primary w-100"
                                            icon="fa-calendar">
                                        Upcoming (Next 30 Days)
                                    </button>
                                </setting>


                            </group>
                            <!-- SLA Escalation Rules -->
                            <group class="row mt16 o_settings_container">
                                <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                    SLA Escalation Rules
                                </div>


                                <setting class="col-lg-12">
                                    <field name="sla_escalation_rules"
                                           placeholder="Define subtask-specific SLA escalation rules..."
                                           nolabel="1"/>
                                </setting>
                            </group>


                            <!-- Escalation Owners -->
                            <group string="Escalation Owners">
                                <group col="2">


                                    <div class="o_form_label">Amber (&lt;= 3 Days Remaining)</div>
                                    <field name="sla_amber_user_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>


                                    <div class="o_form_label">Red (Overdue)</div>
                                    <field name="sla_red_user_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>


                                    <div class="o_form_label">Overdue +3 Days</div>
                                    <field name="sla_overdue_3_user_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>


                                    <div class="o_form_label">Overdue +6 Days</div>
                                    <field name="sla_overdue_6_user_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>


                                </group>
                            </group>


                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

