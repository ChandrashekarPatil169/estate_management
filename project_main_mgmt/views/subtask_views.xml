    <record id="action_project_subtask" model="ir.actions.act_window">
        <field name="name">Subtasks</field>
        <field name="res_model">project.subtask</field>
        <field name="view_mode">kanban,list,form,activity,pivot,graph,calendar</field>
    </record>
    <record id="view_project_subtask_stage_form" model="ir.ui.view">
        <field name="name">project.subtask.stage.form</field>
        <field name="model">project.subtask.stage</field>
        <field name="arch" type="xml">
            <form string="Subtask Stage">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="progress"/>
                        <field name="fold"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_project_subtask_stage_list" model="ir.ui.view">
        <field name="name">project.subtask.stage.list</field>
        <field name="model">project.subtask.stage</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="progress"/>
                <field name="fold"/>
            </list>
        </field>
    </record>
    <record id="view_project_subtask_timeline" model="ir.ui.view">
        <field name="name">project.subtask.timeline</field>
        <field name="model">project.subtask</field>
        <field name="type">timeline</field>
        <field name="arch" type="xml">

            <timeline
                    string="Subtask Timeline"
                    date_start="planned_start_date"
                    date_stop="planned_end_date"
                    default_group_by="assignee_id"
                    event_open_popup="true"
            >

                <!-- Load Required Fields -->
                <field name="name"/>
                <field name="project_id"/>
                <field name="story_id"/>
                <field name="assignee_id"/>
                <field name="estimate"/>
                <field name="status"/>
                <field name="planned_start_date"/>
                <field name="planned_end_date"/>
                <field name="expected_end_date"/>
                <field name="completed_date"/>
                <field name="subtask_progress"/>

                <templates>
                    <t t-name="timeline-item">
                        <div style="white-space: nowrap; font-size: 13px;">

                            <!-- Subtask Name -->

                            <t t-out="record.name"/>

                            <!-- Planned Dates -->
                            <t t-if="record.planned_start_date and record.planned_end_date">
                                | Planned:
                                <t t-out="record.planned_start_date"/>
                                -
                                <t t-out="record.planned_end_date"/>
                            </t>

                            <!-- Expected -->
                            <t t-if="record.expected_end_date">
                                |
                                <span style="color:#dc3545;">
                                    Exp:
                                    <t t-out="record.expected_end_date"/>
                                </span>
                            </t>

                            <!-- Completed -->
                            <t t-if="record.completed_date">
                                |
                                <span style="color:#2ecb71;">
                                    Done:
                                    <t t-out="record.completed_date"/>
                                </span>
                            </t>
                            <!-- PROJECT PROGRESS BAR -->

                            <t t-set="progress" t-value="record.subtask_progress || 0"/>

                            <t t-set="bar_color"
                               t-value="progress &lt; 30
                                        ? '#dc3545'
                                        : (progress &lt; 70
                                        ? '#f4d03f'
                                        : '#2ecb71')"/>

                            <div style="margin-top:5px; width:200px;">
                                <div style="background:#e9ecef; height:6px; border-radius:4px;">
                                    <div t-att-style="'width:' + progress + '%; height:6px; border-radius:4px; background:' + bar_color + ';'">
                                    </div>
                                </div>
                                <small style="font-size:11px;">
                                    <t t-esc="progress.toFixed(1)"/>%
                                </small>
                            </div>

                        </div>
                    </t>
                </templates>

            </timeline>

        </field>
    </record>
    <record id="action_project_subtask_stage" model="ir.actions.act_window">
        <field name="name">Subtask Stages</field>
        <field name="res_model">project.subtask.stage</field>
        <field name="view_mode">list,form,timeline</field>
    </record>

</odoo>