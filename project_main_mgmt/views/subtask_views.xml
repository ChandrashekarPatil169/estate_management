    <record id="view_project_subtask_activity" model="ir.ui.view">
        <field name="name">project.subtask.activity</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <activity string="Subtask Activities">
                <field name="name"/>
                <field name="assignee_id"/>
            </activity>
        </field>
    </record>

    <!-- ================================= -->
    <!-- PIVOT VIEW -->
    <!-- ================================= -->
    <record id="view_project_subtask_pivot" model="ir.ui.view">
        <field name="name">project.subtask.pivot</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <pivot string="Subtask Analysis">
                <field name="project_id" type="row"/>
                <field name="status" type="col"/>
                <field name="estimate" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="view_project_subtask_graph" model="ir.ui.view">
        <field name="name">project.subtask.graph</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <graph string="Subtask Graph" type="bar">
                <field name="project_id"/>
                <field name="estimate" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="view_project_subtask_calendar" model="ir.ui.view">
        <field name="name">project.subtask.calendar</field>
        <field name="model">project.subtask</field>
        <field name="arch" type="xml">
            <calendar string="Subtasks"
                      date_start="planned_start_date"
                      date_stop="planned_end_date"
                      color="assignee_id">
                <field name="name"/>
                <field name="project_id"/>
            </calendar>
        </field>
    </record>

