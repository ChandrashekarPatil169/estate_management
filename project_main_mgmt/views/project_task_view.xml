    <record id="view_task_stage_form_inherit_progress" model="ir.ui.view">
        <field name="name">project.task.stage.form.progress</field>
        <field name="model">project.task.type</field>
        <field name="inherit_id" ref="project.task_type_edit"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='sequence']" position="after">
                <field name="progress"/>
            </xpath>

        </field>
    </record>
    <record id="view_task_tree_progress" model="ir.ui.view">
        <field name="name">project.task.tree.progress</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>   <!-- main list view -->
        <field name="arch" type="xml">

            <!-- add after name -->
            <xpath expr="//field[@name='stage_id']" position="after">
                <field name="task_progress" widget="progressbar"/>
            </xpath>

        </field>
    </record>


