<odoo>

    <record id="view_product_backlog_type_list" model="ir.ui.view">
        <field name="name">product.backlog.type.list</field>
        <field name="model">product.backlog.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_product_backlog_type_form" model="ir.ui.view">
        <field name="name">product.backlog.type.form</field>
        <field name="model">product.backlog.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_backlog_type" model="ir.actions.act_window">
        <field name="name">Backlog Types</field>
        <field name="res_model">product.backlog.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Backlog Types
            </p>
            <p>
                Define and manage reusable backlog categories such as Web, Mobile, API, etc.
            </p>
        </field>
    </record>
    <menuitem id="menu_product_backlog_type"
              name="Backlog Types"
              parent="project.menu_project_config"
              action="action_product_backlog_type"/>

</odoo>