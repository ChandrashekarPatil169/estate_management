                            <!--                        <setting class="col-lg-6">-->
                            <!--                            <field name="sla_next_escalation_at" readonly="1"/>-->
                            <!--                        </setting>-->


                            <!--                        &lt;!&ndash; Reminder Configuration &ndash;&gt;-->
                            <!--                        <setting class="col-lg-6">-->
                            <!--                            <field name="sla_reminder_policy"/>-->
                            <!--                        </setting>-->

                            <!--                        &lt;!&ndash; Escalation Summary (Readonly Info) &ndash;&gt;-->
                            <!--                        <setting class="col-lg-6">-->
                            <!--                            <field name="sla_escalation_policy"/>-->
                            <!--                        </setting>-->

                        </group>

                        <!-- ======================= -->
                        <!-- ESCALATION OWNERS + REMINDER TIMINGS -->
                        <!-- ======================= -->

                        <group string="Escalation Owners and Reminder Timings">

                            <group col="2">

                                <!-- Row 1 -->
                                <div class="o_form_label">Amber (&lt;72h before deadline)</div>
                                <field name="sla_amber_user_ids"
                                       widget="many2many_tags"
                                       nolabel="1"/>

                                <!-- Row 2 -->
                                <div class="o_form_label">Red (At Deadline)</div>
                                <field name="sla_red_user_ids"
                                       widget="many2many_tags"
                                       nolabel="1"/>

                                <!-- Row 3 -->
                                <div class="o_form_label">Overdue +3 Days</div>
                                <field name="sla_overdue_3_user_ids"
                                       widget="many2many_tags"
                                       nolabel="1"/>

                                <!-- Row 4 -->
                                <div class="o_form_label">Overdue +6 Days</div>
                                <field name="sla_overdue_6_user_ids"
                                       widget="many2many_tags"
                                       nolabel="1"/>

                            </group>

                        </group>

