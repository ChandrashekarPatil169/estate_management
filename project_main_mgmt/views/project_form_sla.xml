<odoo>
    <data>
        <record id="view_project_form_hide_date" model="ir.ui.view">
            <field name="name">project.project.form.hide.date</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_start']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>


        <record id="view_project_form_sla" model="ir.ui.view">
            <field name="name">project.project.form.sla</field>
            <field name="model">project.project</field>

            <!-- Inherit project form -->
            <field name="inherit_id" search="[('name','=','project.project.form')]"/>

            <field name="arch" type="xml">


                <!-- 1. Adding 2 Fields (e.g., in the main group) -->
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="planned_start_date"/>
                    <field name="planned_end_date"/>
                </xpath>


                <!-- Add SLA tab -->
                <xpath expr="//notebook/page[@name='settings']" position="after">
                    <page name="sla" string="SLA">

                        <!-- ======================= -->
                        <!-- SLA OVERVIEW -->
                        <!-- ======================= -->
                        <group class="row mt16 o_settings_container">
                            <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                SLA Overview
                            </div>

                            <setting class="col-lg-12">
                                <field name="sla_risk"
                                       widget="badge"
                                       decoration-success="sla_risk == 'green'"
                                       decoration-warning="sla_risk == 'amber'"
                                       decoration-danger="sla_risk == 'red'"/>
                                <field name="sla_days_label" widget="badge"/>
                            </setting>
                        </group>


                        <!-- ======================= -->
                        <!-- SLA MONITORING -->
                        <!-- ======================= -->
                        <group class="row mt16 o_settings_container">
                            <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                SLA Monitoring
                            </div>

                            <setting class="col-lg-12">
                                <button
                                        name="action_open_sla_monitoring"
                                        type="object"
                                        class="btn btn-link p-0"
                                        icon="fa-shield">
                                    Open SLA Monitoring
                                </button>
                            </setting>
                        </group>

                        <group class="row mt16 o_settings_container">

                            <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                SLA Deadlines
                            </div>

                            <setting class="col-lg-6">
                                <button name="action_open_story_sla_7_days"
                                        type="object"
                                        class="btn btn-outline-primary w-100"
                                        icon="fa-calendar">
                                    Upcoming (Next 7 Days)
                                </button>
                            </setting>

                            <setting class="col-lg-6">
                                <button name="action_open_story_sla_30_days"
                                        type="object"
                                        class="btn btn-outline-primary w-100"
                                        icon="fa-calendar">
                                    Upcoming (Next 30 Days)
                                </button>
                            </setting>

                        </group>

                        <group class="row mt16 o_settings_container">

                            <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                SLA Escalation rules
                            </div>

                            <!-- Free Text Rules -->
                            <setting class="col-lg-12">
                                <field name="sla_escalation_rules"
                                       placeholder="Define project-specific SLA escalation governance rules..."
                                       nolabel="1"/>
                            </setting>


                            <!--                        <setting class="col-lg-6">-->
                            <!--                            <field name="sla_current_recipients" readonly="1"/>-->
                            <!--                        </setting>-->

                            <!--                        &lt;!&ndash; Reminder Timings &ndash;&gt;-->
