            </form>
        </field>
    </record>
    <record id="view_project_form_add_backlog_page" model="ir.ui.view">
        <field name="name">project.project.form.add.backlog.page</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <!-- Add new tab -->
            <xpath expr="//notebook" position="inside">

                <!--                <page string="Product Backlogs" invisible="category != 'software'">-->
                <page string="Product Backlogs"
                      invisible="category != 'software' or not enable_backlog_flow">

                    <field name="product_backlog_ids"
                           context="{'default_project_id': id}">

                        <list editable="bottom">
                            <field name="name"/>
                            <field name="status"/>

                            <!-- 🔥 SHOW PROGRESS -->
                            <field name="backlog_progress"
                                   widget="progressbar"
                                   options="{'max_value':100}"/>

                            <field name="planned_end_date"/>
                            <field name="sla_days_label"/>
                        </list>

                        <form>
                            <sheet>
                                <group>
                                    <field name="name"/>
                                    <field name="project_id" readonly="1"/>
                                    <field name="status"/>
                                    <field name="planned_end_date"/>
                                    <field name="backlog_progress"
                                           widget="progressbar"/>
                                </group>
                            </sheet>
                        </form>

                    </field>

                </page>
                <page string="User Stories"
                      invisible="enable_backlog_flow">

                    <field name="user_story_ids"
                           context="{'default_project_id': id}">

                        <list editable="bottom">
                            <field name="name"/>
                            <field name="priority"/>
                            <field name="status"/>
                            <field name="task_avg_progress"
                                   string="Progress %"
                                   widget="progressbar"
                                   options="{'max_value': 100}"/>
                        </list>

                        <form>
                            <sheet>
                                <group>
                                    <field name="name"/>
                                    <field name="project_id" readonly="1"/>
                                    <field name="status"/>
                                    <field name="task_avg_progress"
                                           widget="progressbar"/>
                                </group>
                            </sheet>
                        </form>

                    </field>
                </page>

            </xpath>

        </field>
    </record>

