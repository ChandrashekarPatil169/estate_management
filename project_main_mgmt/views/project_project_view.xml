                                        </div>
                                        <a type="object"
                                           name="action_open_sla_monitoring"
                                           class="stretched-link"/>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>

                    <!-- ================= STORY ================= -->
                    <field name="story_ids" invisible="sla_level != 'story'" readonly="1">
                        <kanban default_group_by="sla_stage" records_draggable="0">
                            <field name="sla_stage"/>
                            <field name="name"/>
                            <field name="sla_days_label"/>

                            <templates>
                                <t t-name="card">
                                    <div class="o_kanban_record o_kanban_global_click"
                                         t-att-class="
                                        record.sla_stage.raw_value == 'green' and 'bg-success-subtle' or
                                        record.sla_stage.raw_value == 'amber' and 'bg-warning-subtle' or
                                        record.sla_stage.raw_value == 'red' and 'bg-danger-subtle' or
                                        record.sla_stage.raw_value == 'red_3' and 'bg-danger text-white' or
                                        record.sla_stage.raw_value == 'red_6' and 'bg-danger fw-bold text-white'
                                     ">
                                        <strong>
                                            <field name="name"/>
                                        </strong>
                                        <div class="text-muted small">
                                            <field name="sla_days_label"/>
                                        </div>
                                        <a type="object"
                                           name="action_open_sla_monitoring"
                                           class="stretched-link"/>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>

                    <!-- ================= TASK ================= -->
                    <field name="task_ids" invisible="sla_level != 'task'" readonly="1">
                        <kanban default_group_by="sla_stage" records_draggable="0">
                            <field name="sla_stage"/>
                            <field name="name"/>
                            <field name="sla_days_label"/>

                            <templates>
                                <t t-name="card">
                                    <div class="o_kanban_record o_kanban_global_click"
                                         t-att-class="
                                        record.sla_stage.raw_value == 'green' and 'bg-success-subtle' or
                                        record.sla_stage.raw_value == 'amber' and 'bg-warning-subtle' or
                                        record.sla_stage.raw_value == 'red' and 'bg-danger-subtle' or
                                        record.sla_stage.raw_value == 'red_3' and 'bg-danger text-white' or
                                        record.sla_stage.raw_value == 'red_6' and 'bg-danger fw-bold text-white'
                                     ">
                                        <strong>
                                            <field name="name"/>
                                        </strong>
                                        <div class="text-muted small">
                                            <field name="sla_days_label"/>
                                        </div>
                                        <a type="object"
                                           name="action_open_sla_monitoring"
                                           class="stretched-link"/>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                    <!-- ================= SUBTASK ================= -->
                    <field name="subtask_ids" invisible="sla_level != 'subtask'" readonly="1">
                        <kanban default_group_by="sla_stage" records_draggable="0">
                            <field name="sla_stage"/>
                            <field name="name"/>
                            <field name="sla_days_label"/>
                            <field name="task_id"/>

                            <templates>
                                <t t-name="card">
                                    <div class="o_kanban_record o_kanban_global_click"
                                         t-att-class="
