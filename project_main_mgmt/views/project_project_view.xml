    <record id="view_project_kanban_toggle_backlog_flow" model="ir.ui.view">
        <field name="name">project.project.kanban.toggle.backlog.flow</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">

            <!-- 1. MUST include both fields so Owl can read them -->
            <xpath expr="//kanban" position="inside">
                <field name="enable_backlog_flow"/>
                <field name="category"/>
            </xpath>

            <!-- 2. Apply the t-if to the button -->
            <xpath expr="//div[contains(@class, 'o_project_kanban_boxes')]" position="inside">
                <button type="object"
                        name="action_toggle_backlog_flow"
                        class="btn btn-sm p-0 ms-2"
                        title="Enable / Disable Backlog &amp; Epic"
                        t-if="record.category.raw_value == 'software'">

                    <i class="fa fa-toggle-on text-success"
                       t-if="record.enable_backlog_flow.raw_value"/>
                    <i class="fa fa-toggle-off text-muted"
                       t-if="!record.enable_backlog_flow.raw_value"/>
                </button>
            </xpath>

        </field>
    </record>


    <record id="view_project_kanban_add_dates" model="ir.ui.view">
        <field name="name">project.project.kanban.add.dates</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">
            <!-- 🔥 VERY IMPORTANT: LOAD FIELD -->
            <xpath expr="//kanban" position="inside">
                <field name="project_progress"/>
                <field name="progress_color"/>
            </xpath>

            <!-- ADD FIELDS AFTER PROJECT NAME -->
            <xpath expr="//t[@t-name='card']//div[contains(@class,'o_project_kanban_body')]" position="inside">

                <!-- 🔥 YOUR NEW SECTION -->
                <div class="text-muted small mt-2">

                    <div>
                        <b>Start:</b>
                        <field name="planned_start_date"/>
                    </div>

                    <div>
                        <b>End:</b>
                        <field name="planned_end_date"/>
                    </div>

                    <div>
                        <b>Expected End:</b>
                        <field name="expected_end_date"/>
                    </div>

                    <div class="text-primary fw-bold">
                        <b>Estimate:</b>
                        <field name="estimate"/>
                        hrs
                    </div>
                    <div class="progress mt-2" style="height:8px;">
                        <div t-att-class="'progress-bar ' + (record.progress_color.raw_value or 'bg-primary')"
                             role="progressbar"
                             t-att-style="'width:' + (record.project_progress.raw_value or 0) + '%;'">
                        </div>
                    </div>

                    <div class="small text-muted mt-1">
                        <t t-esc="record.project_progress.raw_value or 0"/>%
                    </div>

                </div>

            </xpath>

        </field>
    </record>


