<odoo>

    <record id="view_project_form_product_backlog_button" model="ir.ui.view">
        <field name="name">project.project.form.product.backlog.button</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="priority"/>
            </xpath>
            <!-- ADD THE DATE FIELD HERE: Placed after the native start date -->
            <xpath expr="//field[@name='date_start']" position="after">
                <field name="expected_end_date" widget="date"/>
                <field name="completed_date" widget="date" readonly="1"/>
            </xpath>

            <!--            <xpath expr="//div[@name='button_box']" position="inside">-->
            <!--            <xpath expr="//button[@name='action_open_sub_projects']" position="after">-->
            <!--                <button name="action_view_product_backlogs"-->
            <!--                        type="object"-->
            <!--                        class="oe_stat_button"-->
            <!--                        icon="fa-list"-->
            <!--                        invisible="category != 'software'">-->
            <!--                    <field name="backlog_count"-->
            <!--                           string="Product Backlogs"-->
            <!--                           widget="statinfo"/>-->
            <!--                </button>-->

            <!--            </xpath>-->
            <!-- This single XPath handles BOTH positions at once -->
            <xpath expr="//div[@name='button_box']/button[1]" position="before">
                <!-- 1st Position -->
                <button type="object"
                        name="action_open_sub_projects"
                        class="oe_stat_button"
                        icon="fa-sitemap">
                    <field name="sub_project_count" widget="statinfo" string="Sub-Projects"/>
                </button>

                <!-- 2nd Position (placed immediately after the 1st one) -->
                <button name="action_view_product_backlogs"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-list"
                        invisible="category != 'software' or not enable_backlog_flow">
                    <field name="backlog_count"
                           string="Product Backlogs"
                           widget="statinfo"/>
                </button>
            </xpath>


            <xpath expr="//field[@name='name']" position="after">
                <div class="mt-2">
                    <span class="o_form_label">Project Progress</span>
                    <field name="project_progress" widget="progressbar" options="{'max_value':100}"/>
                </div>
            </xpath>


            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_sla_selector"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-shield">
                    <div class="o_stat_info">
                        <span class="o_stat_text">SLA Monitor</span>
                    </div>
                </button>
            </xpath>

        </field>
    </record>


    <record id="view_project_form_epic_button" model="ir.ui.view">
        <field name="name">project.project.form.epic.button</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <!--            <xpath expr="//div[@name='button_box']" position="inside">-->
            <xpath expr="//button[@name='action_view_product_backlogs']" position="after">


                <button name="action_view_project_epics"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-flag"
                        invisible="category != 'software' or not enable_backlog_flow">

                    <field name="epic_count"
                           string="Epics"
                           widget="statinfo"/>
                </button>

            </xpath>

        </field>
    </record>

    <record id="view_project_form_subtask_button" model="ir.ui.view">
        <field name="name">project.project.form.subtask.button</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_view_tasks']" position="after">
                <button name="action_view_project_subtasks"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tasks"
                        invisible="category != 'software'">

                    <field name="subtask_count"
                           string="Subtasks"
                           widget="statinfo"/>
                </button>

            </xpath>

        </field>
    </record>

    <record id="view_project_form_story_button" model="ir.ui.view">
        <field name="name">project.project.form.story.button</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_view_tasks']" position="before">
                <button name="action_view_project_user_stories"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-book"
                        invisible="category != 'software'">

                    <field name="user_story_count"
                           string="User Stories"
                           widget="statinfo"/>
                </button>

            </xpath>

        </field>
    </record>


    <record id="project_kanban_extend_progress" model="ir.ui.view">
        <field name="name">project.kanban.extend.progress</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//progressbar[@field='last_update_status']" position="attributes">
                <attribute name="colors">
                    {
                    "new": "secondary",
                    "on_track": "success",
                    "at_risk": "warning",
                    "off_track": "danger",
                    "on_hold": "info",
                    "review": "primary",
                    "done": "purple",
                    "cancelled": "dark"
                    }
                </attribute>
            </xpath>
        </field>
    </record>

    <record id="view_sla_monitor_selector_form" model="ir.ui.view">
        <field name="name">sla.monitor.selector.form</field>
        <field name="model">sla.monitor.selector</field>
        <field name="arch" type="xml">
            <form string="SLA Monitoring">
                <sheet>


                    <!--                    <group col="2">-->
                    <!--                        <field name="project_id"-->
                    <!--                               options="{'no_create': True, 'no_open': True}"/>-->
                    <!--                        <field name="sla_level"-->
                    <!--                               widget="radio"-->
                    <!--                               options="{'horizontal': true}"/>-->
                    <!--                    </group>-->

                    <group col="2">
                        <field name="project_id"
                               options="{'no_create': True, 'no_open': True}"/>

                        <!-- Ensure this is present in the view for the logic to work -->
                        <field name="enable_backlog_flow" invisible="1"/>

                        <!-- WHEN TOGGLE IS TRUE: Show full sla_level -->
                        <field name="sla_level"
                               widget="radio"
                               options="{'horizontal': true}"
                               invisible="not enable_backlog_flow"/>

                        <!-- WHEN TOGGLE IS FALSE: Show restricted sla_level -->
                        <field name="sla_level_restricted"
                               widget="radio"
                               options="{'horizontal': true}"
                               invisible="enable_backlog_flow"/>
                    </group>
                    <!--                    <group col="2">-->
                    <!--                        <field name="enable_backlog_flow" invisible="1"/>-->

                    <!--                        &lt;!&ndash; Show FULL list when toggle is ON &ndash;&gt;-->
                    <!--                        <field name="sla_level"-->
                    <!--                               widget="radio"-->
                    <!--                               options="{'horizontal': true}"-->
                    <!--                               invisible="not enable_backlog_flow"/>-->

                    <!--                        &lt;!&ndash; Show RESTRICTED list when toggle is OFF &ndash;&gt;-->
                    <!--                        <field name="sla_level_restricted"-->
                    <!--                               widget="radio"-->
                    <!--                               options="{'horizontal': true}"-->
                    <!--                               invisible="enable_backlog_flow"/>-->
                    <!--                    </group>-->


                    <separator string="SLA Status Dashboard"/>

                    <!-- ================= PROJECT ================= -->
                    <field name="project_ids" invisible="sla_level != 'project'" readonly="1">
                        <kanban default_group_by="sla_stage" records_draggable="0">
                            <field name="sla_stage"/>
                            <field name="name"/>
                            <field name="sla_days_label"/>

                            <templates>
                                <t t-name="card">
                                    <div class="o_kanban_record o_kanban_global_click"
                                         t-att-class="
                                        record.sla_stage.raw_value == 'green' and 'bg-success-subtle' or
                                        record.sla_stage.raw_value == 'amber' and 'bg-warning-subtle' or
                                        record.sla_stage.raw_value == 'red' and 'bg-danger-subtle' or
                                        record.sla_stage.raw_value == 'red_3' and 'bg-danger text-white' or
                                        record.sla_stage.raw_value == 'red_6' and 'bg-danger fw-bold text-white'
                                     ">
                                        <strong>
                                            <field name="name"/>
                                        </strong>
                                        <div class="text-muted small mt-1">
                                            <field name="sla_days_label"/>
                                        </div>
                                        <a type="object"
                                           name="action_open_sla_monitoring"
                                           class="stretched-link"/>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>

                    <!-- ================= BACKLOG ================= -->
                    <field name="backlog_ids" invisible="sla_level != 'backlog'" readonly="1">
                        <kanban default_group_by="sla_stage" records_draggable="0">
                            <field name="sla_stage"/>
                            <field name="name"/>
                            <field name="sla_days_label"/>

                            <templates>
                                <t t-name="card">
                                    <div class="o_kanban_record o_kanban_global_click"
                                         t-att-class="
                                        record.sla_stage.raw_value == 'green' and 'bg-success-subtle' or
                                        record.sla_stage.raw_value == 'amber' and 'bg-warning-subtle' or
                                        record.sla_stage.raw_value == 'red' and 'bg-danger-subtle' or
                                        record.sla_stage.raw_value == 'red_3' and 'bg-danger text-white' or
                                        record.sla_stage.raw_value == 'red_6' and 'bg-danger fw-bold text-white'
                                     ">
                                        <strong>
                                            <field name="name"/>
                                        </strong>
                                        <div class="text-muted small">
                                            <field name="sla_days_label"/>
                                        </div>
                                        <a type="object"
                                           name="action_open_sla_monitoring"
                                           class="stretched-link"/>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>

                    <!-- ================= EPIC ================= -->
                    <field name="epic_ids" invisible="sla_level != 'epic'" readonly="1">
                        <kanban default_group_by="sla_stage" records_draggable="0">
                            <field name="sla_stage"/>
                            <field name="name"/>
                            <field name="sla_days_label"/>

                            <templates>
                                <t t-name="card">
                                    <div class="o_kanban_record o_kanban_global_click"
