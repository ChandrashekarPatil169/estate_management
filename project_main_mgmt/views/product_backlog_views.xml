<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================= -->
    <!-- LIST VIEW -->
    <!-- ========================= -->
    <record id="view_product_backlog_list" model="ir.ui.view">
        <field name="name">product.backlog.list</field>
        <field name="model">product.backlog</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="owner_id"/>
                <field name="backlog_type_id"/>
                <field name="status"/>
                <field name="backlog_progress"
                       widget="progressbar"
                       options="{'max_value':100}"/>

            </list>
        </field>
    </record>

    <!-- ========================= -->
    <!-- FORM VIEW -->
    <!-- ========================= -->

    <record id="view_product_backlog_form" model="ir.ui.view">
        <field name="name">product.backlog.form</field>
        <field name="model">product.backlog</field>
        <field name="arch" type="xml">
            <form string="Product Backlog">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="owner_id"/>
                        <field name="backlog_type_id"/>
                        <field name="priority"/>
                        <field name="status"/>
                        <field name="planned_start_date"/>
                        <field name="planned_end_date"/>
                        <field name="expected_end_date"/>
                        <field name="completed_date" readonly="1"/>
                        <field name="backlog_progress"
                               widget="progressbar"
                               options="{'max_value':100}"/>

                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>

                        <page string="Epics">
                            <field name="epic_ids"
                                   context="{
                                       'default_backlog_id': id,
                                       'default_project_id': project_id
                                   }">


                                <!-- TABLE (same as Role Details) -->
                                <list create="true" delete="true" edit="true">
                                    <field name="name"/>
                                    <field name="priority"/>
                                    <field name="epic_progress"
                                           widget="progressbar"
                                    />
                                    <field name="epic_status"/>
                                    <field name="target_milestone"/>
                                    <field name="story_count"/>
                                </list>

                                <!-- FORM (this opens when Add a line is clicked) -->
                                <form string="Epic">
                                    <sheet>
                                        <group>
                                            <field name="name"/>
                                            <field name="project_id"/>
                                            <field name="backlog_type_id"/>
                                            <field name="epic_status"/>
                                            <field name="priority"/>
                                            <field name="owner_id"/>
                                        </group>

                                        <group>
                                            <field name="target_milestone"/>
                                            <field name="planned_start_date"/>
                                            <field name="planned_end_date"/>
                                            <field name="expected_end_date"/>
                                        </group>
                                    </sheet>
                                </form>

                            </field>
                        </page>
                        <page string="Governance">

                            <group>
                                <!-- Select who can approve -->
                                <field name="approver_ids"
                                       widget="many2many_tags"
                                       options="{'no_create': True}"/>

                                <field name="evidence_required"
                                       options="{'resizable': false}"
                                       placeholder="Add evidence here..."/>

                                <!-- Audit info -->
                                <field name="approved_by_id" readonly="1"/>

                                <!-- Internal flag -->
                                <field name="is_done" invisible="1"/>

                            </group>

                            <group>
                                <button name="action_mark_done"
                                        type="object"
                                        string="Approve &amp; Mark Done"
                                        class="btn-primary"
                                        invisible="is_done"/>
                            </group>

                        </page>

                        <page string="Documents" name="documents_page">
                            <field name="document_ids" widget="many2many_binary" string="Add Attachments"/>
                        </page>
                        <page string="Notes">
                            <field name="inherited_notes" readonly="1" widget="html"/>
                        </page>
                        <page name="sla" string="SLA">

                            <!-- ======================
                                 SLA OVERVIEW
                            ======================= -->
                            <group class="row mt16 o_settings_container">
                                <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                    SLA Overview
                                </div>

                                <setting class="col-lg-12">
                                    <field name="sla_risk"
                                           widget="badge"
                                           decoration-success="sla_risk == 'green'"
                                           decoration-warning="sla_risk == 'amber'"
                                           decoration-danger="sla_risk == 'red'"/>
                                    <field name="sla_days_label" widget="badge"/>
                                </setting>
                            </group>

                            <!-- ======================
                                 SLA MONITORING
                            ======================= -->
                            <group class="row mt16 o_settings_container">
                                <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                    SLA Monitoring (Stories)
                                </div>

                                <setting class="col-lg-12">
                                    <button name="action_open_sla_monitoring"
                                            type="object"
                                            class="btn btn-link p-0"
                                            icon="fa-shield">
                                        Open SLA Monitoring
                                    </button>
                                </setting>
                            </group>

                            <!-- ======================
                                 SLA DEADLINES
                            ======================= -->
                            <group class="row mt16 o_settings_container">
                                <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                    SLA Deadlines (Stories)
                                </div>

                                <setting class="col-lg-6">
                                    <button name="action_open_story_sla_7_days"
                                            type="object"
                                            class="btn btn-outline-primary w-100"
                                            icon="fa-calendar">
                                        Upcoming Stories (Next 7 Days)
                                    </button>
                                </setting>

                                <setting class="col-lg-6">
                                    <button name="action_open_story_sla_30_days"
                                            type="object"
                                            class="btn btn-outline-primary w-100"
                                            icon="fa-calendar">
                                        Upcoming Stories (Next 30 Days)
                                    </button>
                                </setting>
                            </group>

                            <!-- ======================
                                 SLA ESCALATION RULES
                            ======================= -->
                            <group class="row mt16 o_settings_container">
                                <div class="o_horizontal_separator text-uppercase fw-bolder small mb-3">
                                    SLA Escalation Rules
                                </div>

                                <setting class="col-lg-12">
                                    <field name="sla_escalation_rules"
                                           placeholder="Define backlog-level SLA escalation rules..."
                                           nolabel="1"/>
                                </setting>
                            </group>

                            <!-- ======================
                                 ESCALATION OWNERS
                            ======================= -->
                            <group string="Escalation Owners">
                                <group col="2">

                                    <div class="o_form_label">Amber (≤ 3 Days Remaining)</div>
                                    <field name="sla_amber_user_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>

                                    <div class="o_form_label">Red (Overdue)</div>
                                    <field name="sla_red_user_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>

                                    <div class="o_form_label">Overdue +3 Days</div>
                                    <field name="sla_overdue_3_user_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>

                                    <div class="o_form_label">Overdue +6 Days</div>
                                    <field name="sla_overdue_6_user_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>

                                </group>
                            </group>

                        </page>

                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_product_backlog_form_epic_button" model="ir.ui.view">
        <field name="name">product.backlog.form.epic.button</field>
        <field name="model">product.backlog</field>
        <field name="inherit_id" ref="view_product_backlog_form"/>
