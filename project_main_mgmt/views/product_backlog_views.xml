                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_documents" type="object" class="oe_stat_button" icon="fa-paperclip">
                    <field name="document_count" string="Documents" widget="statinfo"/>
                </button>
            </xpath>
            <!--            <xpath expr="//div[@name='button_box']" position="inside">-->
            <!--                <button name="action_view_documents"-->
            <!--                        type="object"-->
            <!--                        class="oe_stat_button"-->
            <!--                        icon="fa-paperclip">-->
            <!--                    <field name="document_count"-->
            <!--                           string="Documents"-->
            <!--                           widget="statinfo"/>-->
            <!--                </button>-->
            <!--            </xpath>-->
        </field>
    </record>


    <!-- ========================= -->
    <!-- KANBAN VIEW -->
    <!-- ========================= -->
    <record id="view_product_backlog_kanban_custom" model="ir.ui.view">
        <field name="name">product.backlog.kanban.custom</field>
        <field name="model">product.backlog</field>
        <field name="arch" type="xml">

            <kanban default_group_by="status" class="o_kanban_small_column">

                <field name="name"/>
                <field name="project_id"/>
                <field name="subproject_id"/>
                <field name="planned_start_date"/>
                <field name="planned_end_date"/>
                <field name="estimate"/>
                <field name="backlog_progress"/>
                <field name="progress_color"/>

                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record p-3">

                            <!-- 🔵 PROJECT ALWAYS TOP -->
                            <div class="text-info fw-bold small">
                                <field name="project_id"/>
                            </div>

                            <!-- 🟣 SUBPROJECT + BACKLOG -->
                            <div class="fw-bold text-primary fs-5 mb-1">

                                <!-- if subproject exists -->
                                <t t-if="record.subproject_id.raw_value">
                                    <field name="subproject_id"/>
                                    →
                                </t>

                                <!-- backlog -->
                                <field name="name"/>

                            </div>

                            <!-- DATES -->
                            <div class="text-muted small">
                                Start:
                                <field name="planned_start_date"/>
                            </div>

                            <div class="text-muted small">
                                End:
                                <field name="planned_end_date"/>
                            </div>

                            <div>
                                <b>Expected End:</b>
                                <field name="expected_end_date"/>
                            </div>

                            <!-- ESTIMATE -->
                            <div class="text-primary fw-bold mt-1">
                                Estimate:
                                <field name="estimate"/>
                                hrs
                            </div>

                            <div class="progress mt-2" style="height:8px;">
                                <div t-att-class="'progress-bar ' + (record.progress_color.raw_value or 'bg-primary')"
                                     role="progressbar"
                                     t-att-style="'width:' + (record.backlog_progress.raw_value or 0) + '%;'">
                                </div>
                            </div>

                            <div class="small text-muted mt-1">
                                <t t-esc="record.backlog_progress.raw_value or 0"/>%
                            </div>
                            <div class="o_kanban_footer d-flex justify-content-end">
                                <div class="kanban_status_big">
                                    <field name="status"
                                           widget="state_selection"
                                           options="{'clickable': True}"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>

            </kanban>

        </field>
    </record>    <!-- ========================= -->
