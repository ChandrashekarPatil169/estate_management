    <record id="view_product_backlog_timeline" model="ir.ui.view">
        <field name="name">product.backlog.timeline</field>
        <field name="model">product.backlog</field>
        <field name="type">timeline</field>
        <field name="arch" type="xml">
            <timeline
                    string="Product Backlog Timeline"
                    date_start="planned_start_date"
                    date_stop="planned_end_date"
                    default_group_by="owner_id"
                    event_open_popup="true"
                    colors="#2ecb71: status == 'done';
#ec7063: status == 'cancelled';
#f4d03f: status == 'at_risk';
#5dade2: status == 'on_track'"
            >

                <!-- Fields to load -->
                <field name="name"/>
                <field name="project_id"/>
                <field name="owner_id"/>
                <field name="status"/>
                <field name="expected_end_date"/>
                <field name="completed_date"/>
                <field name="backlog_progress"/>


                <templates>
                    <t t-name="timeline-item">
                        <div style="white-space: nowrap; font-size: 13px;">

                            <!-- Backlog Name -->

                            <t t-esc="record.name"/>

                            <!-- Planned Dates -->
                            <t t-if="record.planned_start_date and record.planned_end_date">
                                |
                                Planned:
                                <t t-esc="record.planned_start_date"/>
                                -
                                <t t-esc="record.planned_end_date"/>
                            </t>

                            <!-- Expected End -->
                            <t t-if="record.expected_end_date">
                                |
                                <span class="o_exp_date">
                                    Exp:
                                    <t t-esc="record.expected_end_date"/>
                                </span>
                            </t>

                            <!-- Completed Date -->
                            <t t-if="record.completed_date">
                                |
                                <span class="o_done_date">
                                    Done:
                                    <t t-esc="record.completed_date"/>
                                </span>
                            </t>
                            <t t-set="progress" t-value="record.backlog_progress || 0"/>

                            <t t-set="bar_color"
                               t-value="progress &lt; 30
                                        ? '#dc3545'
                                        : (progress &lt; 70
                                        ? '#f4d03f'
                                        : '#2ecb71')"/>

                            <div style="margin-top:5px; width:200px;">
                                <div style="background:#e9ecef; height:6px; border-radius:4px;">
                                    <div t-att-style="'width:' + progress + '%; height:6px; border-radius:4px; background:' + bar_color + ';'">
                                    </div>
                                </div>
                                <small style="font-size:11px;">
                                    <t t-esc="progress.toFixed(1)"/>%
                                </small>
                            </div>

                        </div>
                    </t>
                </templates>

            </timeline>
        </field>
    </record>


