<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="email_template_subtask_sla_amber" model="mail.template">
    <field name="name">Subtask SLA Amber Alert</field>
    <field name="model_id" ref="project.model_project_task"/>

    <field name="subject">⚠️ Subtask SLA Warning - {{ object.name }}</field>

    <field name="body_html"><![CDATA[
    <html>
        <body>
            <p>Hello,</p>

            <p>
                Subtask <b><t t-esc="object.name"/></b>
                is nearing its SLA deadline.
            </p>

            <p>
                Remaining Days:
                <b><t t-esc="object.sla_days_remaining or 0"/></b>
            </p>

            <p>
                <a t-att-href="object.get_base_url() + '/web#id=%s&model=project.task&view_type=form' % object.id">
                    Open Subtask
                </a>
            </p>
        </body>
    </html>
    ]]></field>
    </record>
    <record id="email_template_subtask_sla_red" model="mail.template">
    <field name="name">Subtask SLA Red Alert</field>
    <field name="model_id" ref="project.model_project_task"/>

    <field name="subject">🚨 Subtask SLA Breach - {{ object.name }}</field>

    <field name="body_html"><![CDATA[
    <html>
        <body>
            <p>
                Subtask <b><t t-esc="object.name"/></b>
                has breached its SLA.
            </p>

            <p>
                Days Remaining:
                <b><t t-esc="object.sla_days_remaining or 0"/></b>
            </p>
        </body>
    </html>
    ]]></field>
    </record>
    <record id="email_template_subtask_sla_red_3" model="mail.template">
    <field name="name">Subtask SLA Overdue +3</field>
    <field name="model_id" ref="project.model_project_task"/>

    <field name="subject">🔥 Subtask SLA Escalation (+3 Days) - {{ object.name }}</field>

    <field name="body_html"><![CDATA[
    <html>
        <body>
            <p>
                Subtask <b><t t-esc="object.name"/></b>
                is overdue by more than 3 days.
            </p>

            <p>
                Overdue Days:
                <b><t t-esc="abs(object.sla_days_remaining or 0)"/></b>
            </p>
        </body>
    </html>
    ]]></field>
    </record>
    <record id="email_template_subtask_sla_red_6" model="mail.template">
    <field name="name">Subtask SLA Overdue +6</field>
    <field name="model_id" ref="project.model_project_task"/>

    <field name="subject">🚨🔥 Critical SLA (+6 Days) - {{ object.name }}</field>

    <field name="body_html"><![CDATA[
    <html>
        <body>
            <p>
                Subtask <b><t t-esc="object.name"/></b>
                is critically overdue.
            </p>

            <p>
                Overdue Days:
                <b><t t-esc="abs(object.sla_days_remaining or 0)"/></b>
            </p>
        </body>
    </html>
    ]]></field>
    </record>

</odoo>