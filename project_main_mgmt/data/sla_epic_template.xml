<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Epic SLA Amber Alert -->
    <record id="email_template_epic_sla_amber" model="mail.template">
        <field name="name">Epic SLA Amber Alert</field>
        <field name="model_id" ref="project_main_mgmt.model_project_epic"/>
        <field name="subject">⚠️ Epic SLA Warning - {{ object.name }}</field>
        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Hello,</p>
                    <p>Epic <b><t t-esc="object.name"/></b> is nearing its SLA deadline.</p>
                    <p>Remaining Days: <b><t t-esc="object.sla_days_remaining"/></b></p>
                    <p>
                        <a t-att-href="object.get_base_url() + '/web#id=%s&model=project.epic&view_type=form' % object.id">
                            Open Epic
                        </a>
                    </p>
                </body>
            </html>
            ]]>
        </field>
    </record>

    <!-- Epic SLA Red Alert -->
    <record id="email_template_epic_sla_red" model="mail.template">
        <field name="name">Epic SLA Red Alert</field>
        <field name="model_id" ref="project_main_mgmt.model_project_epic"/>
        <field name="subject">🚨 Epic SLA Breach - {{ object.name }}</field>
        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Epic <b><t t-esc="object.name"/></b> has breached its SLA.</p>
                    <p>Days Remaining: <b><t t-esc="object.sla_days_remaining"/></b></p>
                </body>
            </html>
            ]]>
        </field>
    </record>

    <!-- Epic SLA Overdue +3 -->
    <record id="email_template_epic_sla_red_3" model="mail.template">
        <field name="name">Epic SLA Overdue +3</field>
        <field name="model_id" ref="project_main_mgmt.model_project_epic"/>
        <field name="subject">🔥 Epic SLA Escalation (+3 Days) - {{ object.name }}</field>
        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Epic <b><t t-esc="object.name"/></b> is overdue by 3+ days.</p>
                    <p>Overdue Days: <b><t t-esc="abs(object.sla_days_remaining)"/></b></p>
                </body>
            </html>
            ]]>
        </field>
    </record>

    <!-- Epic SLA Overdue +6 -->
    <record id="email_template_epic_sla_red_6" model="mail.template">
        <field name="name">Epic SLA Overdue +6</field>
        <field name="model_id" ref="project_main_mgmt.model_project_epic"/>
        <field name="subject">🚨🔥 Critical Epic SLA (+6 Days) - {{ object.name }}</field>
        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Epic <b><t t-esc="object.name"/></b> is critically overdue (6+ days).</p>
                    <p>Overdue Days: <b><t t-esc="abs(object.sla_days_remaining)"/></b></p>
                </body>
            </html>
            ]]>
        </field>
    </record>
</odoo>
