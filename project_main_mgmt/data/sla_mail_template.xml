<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= AMBER ================= -->
    <record id="email_template_sla_amber" model="mail.template">
        <field name="name">SLA Amber Alert</field>
        <field name="model_id" ref="project.model_project_task"/>

        <!--        <field name="email_from">{{ (user.email or 'noreply@example.com') }}</field>-->
<!--       <field name="email_from">{{ (object.company_id.email or 'odoo_master@innspark.in') }}</field>-->

        <!-- ✅ SINGLE LINE ONLY -->
        <field name="subject">⚠️ SLA Warning - {{ object.name }}</field>

        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Hello,</p>

                    <p>
                        Task <b><t t-esc="object.name"/></b> is nearing SLA deadline.
                    </p>

                    <p>
                        Remaining Days:
                        <b><t t-esc="object.sla_days_remaining"/></b>
                    </p>

                    <p>
                        <a t-att-href="object.get_base_url() + '/web#id=%s&model=project.task&view_type=form' % object.id">
                            Open Task
                        </a>
                    </p>
                </body>
            </html>
            ]]>
        </field>
    </record>

    <!-- ================= RED ================= -->
    <record id="email_template_sla_red" model="mail.template">
        <field name="name">SLA Red Alert</field>
        <field name="model_id" ref="project.model_project_task"/>

        <!--        <field name="email_from">{{ (user.email or 'noreply@example.com') }}</field>-->
<!--        <field name="email_from">{{ (object.company_id.email or 'odoo_master@innspark.in') }}</field>-->


        <field name="subject">🚨 SLA Breach - {{ object.name }}</field>

        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>
                        Task <b><t t-esc="object.name"/></b> has breached SLA.
                    </p>

                    <p>
                        Days Remaining:
                        <t t-esc="object.sla_days_remaining"/>
                    </p>
                </body>
            </html>
            ]]>
        </field>
    </record>

