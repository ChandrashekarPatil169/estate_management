        <field name="subject">🔥 SLA Escalation (+3 Days) - {{ object.name }}</field>

        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>
                        Task <b><t t-esc="object.name"/></b> is overdue by 3+ days.
                    </p>
                </body>
            </html>
            ]]>
        </field>
    </record>

