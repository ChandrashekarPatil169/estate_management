<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Project SLA Amber Alert -->
    <record id="email_template_project_sla_amber" model="mail.template">
        <field name="name">Project SLA Amber Alert</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="subject">⚠️ Project SLA Warning - {{ object.name }}</field>
        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Hello,</p>
                    <p>Project <b><t t-esc="object.name"/></b> is nearing its SLA deadline.</p>
                    <p>Remaining Days: <b><t t-esc="object.sla_days_remaining"/></b></p>
                    <p>
                        <a t-att-href="object.get_base_url() + '/web#id=%s&model=project.project&view_type=form' % object.id">
                            Open Project
                        </a>
                    </p>
                </body>
            </html>
            ]]>
        </field>
    </record>

    <!-- Project SLA Red Alert -->
    <record id="email_template_project_sla_red" model="mail.template">
        <field name="name">Project SLA Red Alert</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="subject">🚨 Project SLA Breach - {{ object.name }}</field>
        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Project <b><t t-esc="object.name"/></b> has breached its SLA.</p>
                    <p>Days Remaining: <b><t t-esc="object.sla_days_remaining"/></b></p>
                </body>
            </html>
            ]]>
        </field>
    </record>

    <!-- Project SLA Overdue +3 -->
    <record id="email_template_project_sla_red_3" model="mail.template">
        <field name="name">Project SLA Overdue +3</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="subject">🔥 Project SLA Escalation (+3 Days) - {{ object.name }}</field>
        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Project <b><t t-esc="object.name"/></b> is overdue by 3+ days.</p>
                    <p>Overdue Days: <b><t t-esc="abs(object.sla_days_remaining)"/></b></p>
                </body>
            </html>
            ]]>
        </field>
    </record>

    <!-- Project SLA Overdue +6 -->
    <record id="email_template_project_sla_red_6" model="mail.template">
        <field name="name">Project SLA Overdue +6</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="subject">🚨🔥 Critical Project SLA (+6 Days) - {{ object.name }}</field>
        <field name="body_html">
            <![CDATA[
            <html>
                <body>
                    <p>Project <b><t t-esc="object.name"/></b> is critically overdue (6+ days).</p>
                    <p>Overdue Days: <b><t t-esc="abs(object.sla_days_remaining)"/></b></p>
                </body>
            </html>
            ]]>
        </field>
    </record>
</odoo>
